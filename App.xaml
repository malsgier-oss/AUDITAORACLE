<Application x:Class="WorkAudit.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WorkAudit.Converters"
             Startup="App_Startup">
    <Application.Resources>
        <ResourceDictionary>
            <conv:HexToBrushConverter x:Key="HexToBrushConverter"/>
            <ResourceDictionary.MergedDictionaries>
                <!-- Layout Constants -->
                <ResourceDictionary Source="Styles/LayoutConstants.xaml"/>
                <!-- Icon Resources -->
                <ResourceDictionary Source="Styles/IconResources.xaml"/>
                <!-- Button Styles -->
                <ResourceDictionary Source="Styles/ButtonStyles.xaml"/>
                <!-- Theme loaded at runtime by ThemeService (Light or Dark Midnight) -->
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
