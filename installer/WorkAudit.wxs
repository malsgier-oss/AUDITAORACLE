<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="WorkAudit"
           Manufacturer="WorkAudit"
           Version="1.0.0.0"
           UpgradeCode="12345678-1234-1234-1234-123456789ABC"
           Language="1033"
           Compressed="yes"
           InstallerVersion="500">
    
    <MajorUpgrade DowngradeErrorMessage="A newer version of WorkAudit is already installed." />
    
    <Media Id="1" Cabinet="workaudit.cab" EmbedCab="yes" />

    <!-- Install to Program Files -->
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="WorkAudit" />
    </StandardDirectory>

    <!-- Desktop and Start Menu shortcuts -->
    <StandardDirectory Id="DesktopFolder" />
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="WorkAudit" />
    </StandardDirectory>

    <!-- Main feature -->
    <Feature Id="MainApplication" Title="WorkAudit" Level="1">
      <ComponentGroupRef Id="ApplicationFiles" />
      <ComponentRef Id="ApplicationShortcutDesktop" />
      <ComponentRef Id="ApplicationShortcutStartMenu" />
    </Feature>

    <!-- Desktop shortcut -->
    <Component Id="ApplicationShortcutDesktop" Directory="DesktopFolder" Guid="*">
      <Shortcut Id="DesktopShortcut"
                Name="WorkAudit"
                Description="WorkAudit Document Management System"
                Target="[INSTALLFOLDER]WorkAudit.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveDesktopShortcut" Directory="DesktopFolder" On="uninstall" />
      <RegistryValue Root="HKCU"
                     Key="Software\WorkAudit"
                     Name="DesktopShortcut"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

    <!-- Start Menu shortcut -->
    <Component Id="ApplicationShortcutStartMenu" Directory="ApplicationProgramsFolder" Guid="*">
      <Shortcut Id="StartMenuShortcut"
                Name="WorkAudit"
                Description="WorkAudit Document Management System"
                Target="[INSTALLFOLDER]WorkAudit.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveStartMenuFolder" Directory="ApplicationProgramsFolder" On="uninstall" />
      <RegistryValue Root="HKCU"
                     Key="Software\WorkAudit"
                     Name="StartMenuShortcut"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

    <!-- Uninstall shortcut -->
    <Component Id="UninstallShortcut" Directory="ApplicationProgramsFolder" Guid="*">
      <Shortcut Id="UninstallShortcut"
                Name="Uninstall WorkAudit"
                Description="Uninstall WorkAudit"
                Target="[System64Folder]msiexec.exe"
                Arguments="/x [ProductCode]" />
    </Component>

    <!-- Launch condition: Require .NET 8.0 -->
    <Launch Condition="NETFRAMEWORK45 >= '#461808'" Message="This application requires .NET Framework 4.8 or later." />
    
    <!-- Custom Action: Check for .NET 8.0 Runtime -->
    <CustomActionRef Id="WixDotNetCoreSearch" />

    <!-- UI -->
    <UI>
      <UIRef Id="WixUI_InstallDir" />
      <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="InstallDirDlg" Order="2">1</Publish>
      <Publish Dialog="InstallDirDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" Order="2">1</Publish>
    </UI>
    
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

  </Package>

  <!-- Application files component group -->
  <!-- NOTE: This will be generated by WiX heat.exe command during build -->
  <!-- Run: heat.exe dir "..\bin\Release\net8.0-windows" -cg ApplicationFiles -gg -sfrag -dr INSTALLFOLDER -out ApplicationFiles.wxs -->
  
</Wix>
