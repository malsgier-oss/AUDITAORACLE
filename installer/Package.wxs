<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <!--
    UpgradeCode is fixed. Package version comes from build/WorkAudit.Version.props via PackageVersion define at build time.
    UI: WixUI_InstallDir — welcome, license agreement, install destination folder, ready/progress/exit (default under Program Files\Audita; no DB path in the MSI).
    License RTF: WixUILicenseRtf bind variable in WorkAudit.Installer.wixproj → License.rtf
  -->
  <Package Name="AUDITA"
           Manufacturer="CertisTech.com"
           Version="$(var.PackageVersion)"
           UpgradeCode="C7E73590-3DE9-4A7D-9B7B-1C4EAC5D5F90"
           InstallerVersion="500"
           Scope="perMachine">

    <SummaryInformation Description="AUDITA desktop application"
                        Manufacturer="CertisTech.com" />

    <!-- AllowSameVersionUpgrades enabled: allows in-place upgrades even when ProductVersion is unchanged (continuous rebuilds). -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed."
                  AllowSameVersionUpgrades="yes"
                  Schedule="afterInstallInitialize" />

    <!-- Without this, FindRelatedProducts may not run during the UI sequence, so WIX_UPGRADE_DETECTED stays empty and upgrade-specific dialog text never appears. -->
    <InstallUISequence>
      <FindRelatedProducts Before="AppSearch" />
    </InstallUISequence>

    <MediaTemplate EmbedCab="yes" />

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

    <Feature Id="Main" Title="AUDITA" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentGroupRef Id="ShortcutComponents" />
    </Feature>

    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="Audita" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="AUDITA">
        <Component Id="StartMenuShortcut" Guid="F2D9B6C1-4B7D-4E9C-9F3D-1A2B3C4D5E6F">
          <Shortcut Id="StartMenuWorkAudit"
                    Name="AUDITA"
                    Description="AUDITA"
                    Target="[INSTALLFOLDER]Audita.exe"
                    WorkingDirectory="INSTALLFOLDER" />
          <RemoveFolder Id="RemoveProgramsFolder" On="uninstall" />
          <RegistryValue Root="HKMU"
                         Key="Software\Audita"
                         Name="StartMenu"
                         Type="integer"
                         Value="1"
                         KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="A1B2C3D4-E5F6-7890-ABCD-111122223333">
        <Shortcut Id="DesktopWorkAudit"
                  Name="AUDITA"
                  Target="[INSTALLFOLDER]Audita.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKMU"
                       Key="Software\Audita"
                       Name="Desktop"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>

  </Package>

  <Fragment>
    <!-- Harvested files from self-contained publish (see WorkAudit.Installer.wixproj). -->
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="..\artifacts\msi-app\**" />
    </ComponentGroup>

    <ComponentGroup Id="ShortcutComponents">
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="DesktopShortcut" />
    </ComponentGroup>
  </Fragment>

</Wix>
