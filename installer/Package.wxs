<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <!--
    UpgradeCode is fixed. Package version comes from build/WorkAudit.Version.props via PackageVersion define at build time.
  -->
  <Package Name="AUDITA"
           Manufacturer="CertisTech.com"
           Version="$(var.PackageVersion)"
           UpgradeCode="C7E73590-3DE9-4A7D-9B7B-1C4EAC5D5F90"
           InstallerVersion="500"
           Scope="perMachine">

    <SummaryInformation Description="AUDITA desktop application"
                        Manufacturer="CertisTech.com" />

    <!-- AllowSameVersionUpgrades enabled: allows in-place upgrades even when ProductVersion is unchanged (continuous rebuilds). -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed."
                  AllowSameVersionUpgrades="yes"
                  Schedule="afterInstallInitialize" />

    <!-- Without this, FindRelatedProducts may not run during the UI sequence, so WIX_UPGRADE_DETECTED stays empty and upgrade-specific dialog text never appears. -->
    <InstallUISequence>
      <FindRelatedProducts Before="AppSearch" />
    </InstallUISequence>

    <MediaTemplate EmbedCab="yes" />
    <Property Id="WORKAUDIT_BASE_DIR" Value="C:\ProgramData\Audita\Documents" Secure="yes" />
    <Property Id="WORKAUDIT_ORACLE_CONNECTION" Secure="yes" />
    <!-- Enforce Oracle property for unattended installs; interactive flow can collect it in UI. -->
    <Launch Condition="NOT (REMOVE = 'ALL') AND ((UILevel &gt;= 5) OR WORKAUDIT_ORACLE_CONNECTION)"
            Message="Oracle configuration is required for unattended installs. Provide WORKAUDIT_ORACLE_CONNECTION on the msiexec command line." />
    <Launch Condition="NOT (REMOVE = 'ALL') AND ((UILevel &gt;= 5) OR NOT (WORKAUDIT_ORACLE_CONNECTION &gt;&lt; 'change-me'))"
            Message="WORKAUDIT_ORACLE_CONNECTION cannot contain placeholder credentials (for example: change-me)." />
    <Launch Condition="NOT (REMOVE = 'ALL') AND ((UILevel &gt;= 5) OR ((WORKAUDIT_ORACLE_CONNECTION &gt;&lt; 'User Id=') AND (WORKAUDIT_ORACLE_CONNECTION &gt;&lt; 'Data Source=')))"
            Message="WORKAUDIT_ORACLE_CONNECTION must include User Id= and Data Source= segments." />

    <UI>
      <!-- Reference only the specific dialogs we need, not a full WixUI preset -->
      <UIRef Id="WixUI_Common" />
      <UIRef Id="WixUI_ErrorProgressText" />
      
      <Dialog Id="WorkAuditPathsDlg" Width="370" Height="270" Title="[ProductName] Setup">
        <Control Id="Title" Type="Text" X="15" Y="10" Width="340" Height="25"
                 Text="{\WixUI_Font_Title}AUDITA data locations" />
        <Control Id="DescriptionUpgrade" Type="Text" X="15" Y="38" Width="340" Height="36"
                 Text="This setup will upgrade your existing AUDITA installation. Choose documents storage and Oracle connection configuration."
                 ShowCondition="WIX_UPGRADE_DETECTED" />
        <Control Id="Description" Type="Text" X="15" Y="38" Width="340" Height="22"
                 Text="Choose where AUDITA stores documents and Oracle connection configuration."
                 ShowCondition="NOT WIX_UPGRADE_DETECTED" />

        <Control Id="BaseDirLabel" Type="Text" X="20" Y="74" Width="320" Height="12"
                 Text="Documents folder (WORKAUDIT_BASE_DIR):" />
        <Control Id="BaseDirEdit" Type="Edit" X="20" Y="90" Width="330" Height="18"
                 Property="WORKAUDIT_BASE_DIR" />

        <Control Id="DbPathLabel" Type="Text" X="20" Y="124" Width="330" Height="12"
                 Text="Oracle connection string (WORKAUDIT_ORACLE_CONNECTION):" />
        <Control Id="DbPathEdit" Type="Edit" X="20" Y="140" Width="330" Height="18"
                 Property="WORKAUDIT_ORACLE_CONNECTION" />
        <Control Id="DbPathHint" Type="Text" X="20" Y="162" Width="330" Height="30"
                 Text="Required format: User Id=...;Password=...;Data Source=...; Do not use placeholder values." />

        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="!(loc.WixUIBack)" />
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="!(loc.WixUINext)" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="!(loc.WixUICancel)" />
      </Dialog>

      <!-- Define complete custom dialog flow: Welcome -> Config -> VerifyReady -> Progress -> Exit -->
      
      <!-- Fresh install flow: Welcome -> Config -> VerifyReady -->
      <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="WorkAuditPathsDlg" Order="2" Condition="NOT Installed" />
      <Publish Dialog="WorkAuditPathsDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" Order="2" Condition="NOT Installed" />
      <Publish Dialog="WorkAuditPathsDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg" Order="2" Condition="NOT Installed" />
      
      <!-- Maintenance/upgrade flow: MaintenanceWelcome -> Config -> VerifyReady -->
      <Publish Dialog="MaintenanceWelcomeDlg" Control="Next" Event="NewDialog" Value="WorkAuditPathsDlg" Order="2" Condition="Installed" />
      <Publish Dialog="WorkAuditPathsDlg" Control="Back" Event="NewDialog" Value="MaintenanceWelcomeDlg" Order="2" Condition="Installed" />
      <Publish Dialog="WorkAuditPathsDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg" Order="2" Condition="Installed" />
      
      <!-- Common back navigation from VerifyReady -->
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="WorkAuditPathsDlg" Order="2" Condition="1" />
      
      <Publish Dialog="WorkAuditPathsDlg" Control="Cancel" Event="SpawnDialog" Value="CancelDlg" Condition="1" />
    </UI>

    <Feature Id="Main" Title="AUDITA" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentGroupRef Id="ShortcutComponents" />
      <ComponentRef Id="EnvironmentConfig" />
    </Feature>

    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="Audita" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="AUDITA">
        <Component Id="StartMenuShortcut" Guid="F2D9B6C1-4B7D-4E9C-9F3D-1A2B3C4D5E6F">
          <Shortcut Id="StartMenuWorkAudit"
                    Name="AUDITA"
                    Description="AUDITA"
                    Target="[INSTALLFOLDER]Audita.exe"
                    WorkingDirectory="INSTALLFOLDER" />
          <RemoveFolder Id="RemoveProgramsFolder" On="uninstall" />
          <RegistryValue Root="HKMU"
                         Key="Software\Audita"
                         Name="StartMenu"
                         Type="integer"
                         Value="1"
                         KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="A1B2C3D4-E5F6-7890-ABCD-111122223333">
        <Shortcut Id="DesktopWorkAudit"
                  Name="AUDITA"
                  Target="[INSTALLFOLDER]Audita.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKMU"
                       Key="Software\Audita"
                       Name="Desktop"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <Component Id="EnvironmentConfig" Directory="INSTALLFOLDER" Guid="A6A29B62-8D88-4FB1-B723-97A2688C2274">
      <RegistryValue Root="HKMU"
                     Key="Software\Audita"
                     Name="EnvironmentConfig"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
      <Environment Id="WorkAuditBaseDir"
                   Action="set"
                   Name="WORKAUDIT_BASE_DIR"
                   Part="all"
                   System="yes"
                   Value="[WORKAUDIT_BASE_DIR]" />
      <Environment Id="WorkAuditOracleConnection"
                   Action="set"
                   Name="WORKAUDIT_ORACLE_CONNECTION"
                   Part="all"
                   System="yes"
                   Value="[WORKAUDIT_ORACLE_CONNECTION]" />
    </Component>

  </Package>

  <Fragment>
    <!-- Harvested files from self-contained publish (see WorkAudit.Installer.wixproj). -->
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="..\artifacts\msi-app\**" />
    </ComponentGroup>

    <ComponentGroup Id="ShortcutComponents">
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="DesktopShortcut" />
    </ComponentGroup>
  </Fragment>

</Wix>
