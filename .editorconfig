root = true

[*.cs]
# Production-code analyzer severities are inherited from Directory.Build.props
# (AnalysisLevel=latest-recommended). Keep them at full strength here.

# Roslyn glob: `**/*.cs` does not match .cs files directly under WorkAudit.Tests; include both.
[WorkAudit.Tests/*.cs]
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.CA1711.severity = none

[WorkAudit.Tests/**/*.cs]
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.CA1711.severity = none
