<Window x:Class="WorkAudit.Dialogs.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About" Height="260" Width="420" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="24">
        <StackPanel>
            <TextBlock Text="AUDITA v1.0" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
            <TextBlock Text="Audit Workspace for Documents, Notes &amp; Reporting" Margin="0,16,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
            <TextBlock Text="By www.certistech.com" Margin="0,12,0,0" HorizontalAlignment="Center" Foreground="#666"/>
            <Button Content="OK" Width="80" Height="28" Margin="0,24,0,0" HorizontalAlignment="Center" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
