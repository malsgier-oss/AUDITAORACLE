<Window x:Class="WorkAudit.Dialogs.PasswordResetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change password" Height="380" Width="420" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="SingleBorderWindow"
        Background="{DynamicResource ContentBackground}">
    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0" Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="UserLabel" Grid.Row="0" Text="Change password for: username" Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,12" TextWrapping="Wrap"/>

            <TextBlock Grid.Row="1" Text="New password" Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,4"/>
            <Grid Grid.Row="2" Margin="0,0,0,12">
                <PasswordBox x:Name="PasswordBox" Padding="10,8" Height="36" VerticalAlignment="Top"
                             PasswordChanged="PasswordBox_OnPasswordChanged"/>
                <TextBox x:Name="PasswordPlainText" Padding="10,8" Height="36" VerticalAlignment="Top"
                         Visibility="Collapsed" TextChanged="PasswordPlainText_OnTextChanged"/>
            </Grid>

            <TextBlock Grid.Row="3" Text="Confirm new password" Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,4"/>
            <Grid Grid.Row="4" Margin="0,0,0,8">
                <PasswordBox x:Name="ConfirmPasswordBox" Padding="10,8" Height="36" VerticalAlignment="Top"
                             PasswordChanged="ConfirmPasswordBox_OnPasswordChanged"/>
                <TextBox x:Name="ConfirmPlainText" Padding="10,8" Height="36" VerticalAlignment="Top"
                         Visibility="Collapsed" TextChanged="ConfirmPlainText_OnTextChanged"/>
            </Grid>

            <CheckBox x:Name="ShowPasswordCheck" Grid.Row="5" Content="Show passwords"
                      Margin="0,0,0,12" Foreground="{DynamicResource PrimaryForeground}"
                      Checked="ShowPasswordCheck_OnChecked" Unchecked="ShowPasswordCheck_OnUnchecked"/>

            <TextBlock Grid.Row="6" Text="Password must be 8+ chars, upper, lower, number, special"
                       Foreground="{DynamicResource SecondaryForeground}" FontSize="11" TextWrapping="Wrap" VerticalAlignment="Top" Margin="0,0,0,12"/>

            <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK" Width="80" Height="32" Margin="0,0,8,0"
                        Background="#0E639C" Foreground="White" BorderThickness="0"
                        Click="BtnOk_Click" IsDefault="True"/>
                <Button Content="Cancel" Width="80" Height="32" Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}"
                        BorderThickness="0" IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
