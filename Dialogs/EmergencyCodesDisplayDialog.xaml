<Window x:Class="WorkAudit.Dialogs.EmergencyCodesDisplayDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Emergency access codes" Height="420" Width="520"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{DynamicResource ContentBackground}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="InstructionText" TextWrapping="Wrap" FontSize="13"
                   Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,12"/>

        <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="4" Background="{DynamicResource PanelBackground}">
            <TextBox x:Name="CodesTextBox" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto" Padding="8" FontSize="14"
                     FontFamily="Consolas, Courier New"
                     Background="Transparent" Foreground="{DynamicResource PrimaryForeground}"
                     BorderThickness="0"/>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="CopyBtn" Content="Copy all" Padding="16,6" Margin="0,0,8,0"
                    Click="Copy_Click" Cursor="Hand"/>
            <Button Content="I have saved these" Padding="16,6" IsDefault="True" IsCancel="False"
                    Click="Ok_Click" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
