<Window x:Class="WorkAudit.Dialogs.TeamTaskNoteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Team task note" Height="360" Width="520" MinHeight="280" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ContentBackground}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TaskTitleBlock" Grid.Row="0" FontSize="14" FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryForeground}" TextWrapping="Wrap" Margin="0,0,0,8"/>
        <TextBlock x:Name="HintBlock" Grid.Row="1" FontSize="11" Foreground="{DynamicResource DimForeground}"
                   TextWrapping="Wrap" Margin="0,0,0,8"/>

        <TextBox x:Name="NoteBox" Grid.Row="2" AcceptsReturn="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" Padding="8" Margin="0,0,0,12"
                 SpellCheck.IsEnabled="True"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OkBtn" Content="OK" Padding="16,8" Margin="0,0,8,0" IsDefault="True" Click="OkBtn_Click"
                    Background="#0E639C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="CancelBtn" Content="Cancel" Padding="16,8" IsCancel="True"
                    Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource DimForeground}" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
