<Window x:Class="WorkAudit.Dialogs.SetupWizardDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AUDITA Setup" Height="380" Width="520" WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" Background="{DynamicResource ContentBackground}" WindowStyle="SingleBorderWindow">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="StepTitle" Grid.Row="0" Text="Welcome" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,16"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="StepContent">
                <TextBlock x:Name="StepDescription" Text="" Foreground="{DynamicResource SecondaryForeground}" TextWrapping="Wrap" Margin="0,0,0,20"/>
                <StackPanel x:Name="StepFields"/>
            </StackPanel>
        </ScrollViewer>
        <Border Grid.Row="2" Padding="0,16,0,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BackBtn" Content="Back" Width="80" Height="32" Margin="0,0,8,0" Click="Back_Click"
                        Visibility="Collapsed" Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="NextBtn" Content="Next" Width="80" Height="32" Margin="0,0,8,0" Click="Next_Click"
                        Background="#0E639C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="FinishBtn" Content="Finish" Width="80" Height="32" Click="Finish_Click"
                        Visibility="Collapsed" Background="#0E639C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
