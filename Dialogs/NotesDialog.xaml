<Window x:Class="WorkAudit.Dialogs.NotesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Document Notes" Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PanelBackground}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock x:Name="DocumentNameText" FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryForeground}"/>
            <TextBlock x:Name="NoteCountText" FontSize="12"
                       Foreground="{DynamicResource SecondaryForeground}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Notes List -->
        <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                Background="{DynamicResource ContentBackground}">
            <ScrollViewer VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="NotesListControl" Padding="12">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12" Margin="0,0,0,12"
                                    Background="{DynamicResource PanelBackground}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="4">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header Row -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding TypeIcon}" FontSize="14" Margin="0,0,6,0"/>
                                        <Border Grid.Column="1" Padding="6,2" CornerRadius="3" Background="{Binding SeverityColor}" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Severity}" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding Type}" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,8,0"/>
                                        <TextBlock Grid.Column="4" Text="{Binding CreatedBy}" FontSize="10"
                                                   Foreground="{DynamicResource SecondaryForeground}"/>
                                    </Grid>

                                    <!-- Content -->
                                    <TextBlock Grid.Row="1" Text="{Binding Content}" TextWrapping="Wrap"
                                               Margin="0,8,0,0" Foreground="{DynamicResource PrimaryForeground}"/>

                                    <!-- Footer with Status Management -->
                                    <Grid Grid.Row="2" Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="{Binding CreatedAt}" FontSize="9"
                                                       Foreground="{DynamicResource SecondaryForeground}"/>
                                            <TextBlock Text=" • " FontSize="9"
                                                       Foreground="{DynamicResource SecondaryForeground}" Margin="4,0"/>
                                            <Border Padding="4,1" CornerRadius="2" Margin="0,0,0,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#28A745"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Open">
                                                                <Setter Property="Background" Value="#6C757D"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="InProgress">
                                                                <Setter Property="Background" Value="#FFC107"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Deferred">
                                                                <Setter Property="Background" Value="#17A2B8"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Status}" FontSize="9" Foreground="White" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Status Change Control -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="Status:" FontSize="9" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,4,0"/>
                                            <ComboBox Width="100" FontSize="9" Padding="4,2"
                                                      SelectionChanged="StatusCombo_SelectionChanged"
                                                      Tag="{Binding Id}"
                                                      Loaded="StatusCombo_Loaded">
                                                <ComboBoxItem Content="Open" Tag="Open"/>
                                                <ComboBoxItem Content="In Progress" Tag="InProgress"/>
                                                <ComboBoxItem Content="Deferred" Tag="Deferred"/>
                                                <ComboBoxItem Content="Resolved" Tag="Resolved"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Resolution Details (shown only when resolved) -->
                                    <Border Grid.Row="3" Margin="0,8,0,0" Padding="8" Background="#F0F8FF"
                                            BorderBrush="#B0D4F1" BorderThickness="1" CornerRadius="3">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasResolution}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="✓ Resolution Details" FontWeight="SemiBold"
                                                       Foreground="#28A745" FontSize="10"/>
                                            <TextBlock Margin="0,4,0,0" FontSize="9">
                                                <Run Text="Resolved by " Foreground="{DynamicResource SecondaryForeground}"/>
                                                <Run Text="{Binding ResolvedBy, Mode=OneWay}" FontWeight="SemiBold"
                                                     Foreground="{DynamicResource PrimaryForeground}"/>
                                                <Run Text=" • " Foreground="{DynamicResource SecondaryForeground}"/>
                                                <Run Text="{Binding FormattedResolvedAt, Mode=OneWay}"
                                                     Foreground="{DynamicResource SecondaryForeground}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding ResolutionComment, Mode=OneWay}" TextWrapping="Wrap"
                                                       Margin="0,4,0,0" FontSize="9" FontStyle="Italic"
                                                       Foreground="{DynamicResource PrimaryForeground}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ResolutionComment}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ResolutionComment}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Add Note Section -->
        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock Text="Add New Note" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,8"/>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>

                <!-- Type and Severity Selection -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Type:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="TypeCombo" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="0" Grid.Column="3" Text="Severity:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Grid.Row="0" Grid.Column="4" x:Name="SeverityCombo" Margin="0,0,0,8"/>

                <!-- Note Content -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Note:" VerticalAlignment="Top" Margin="0,8,8,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="4" x:Name="NewNoteContent"
                         MinHeight="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,8,0,8"/>

                <!-- Add Button -->
                <Button Grid.Row="2" Grid.Column="4" x:Name="AddNoteBtn" Content="Add Note"
                        Padding="12,6" HorizontalAlignment="Right" Click="AddNoteBtn_Click"
                        Background="#0078D4" Foreground="White" BorderThickness="0"/>
            </Grid>
        </StackPanel>

        <!-- Close Button -->
        <Button Grid.Row="3" Content="Close" Padding="12,6" Margin="0,12,0,0"
                HorizontalAlignment="Right" Click="CloseBtn_Click"/>
    </Grid>
</Window>
