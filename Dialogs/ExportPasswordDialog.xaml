<Window x:Class="WorkAudit.Dialogs.ExportPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Encrypt Export"
        Width="360" Height="220"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource ContentBackground}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Enter a password to encrypt this export. You will need this password to decrypt the file." 
                   Foreground="{DynamicResource PrimaryForeground}" TextWrapping="Wrap" Margin="0,0,0,12"/>
        <TextBlock Grid.Row="1" Text="Password:" Margin="0,0,0,4" Foreground="{DynamicResource PrimaryForeground}"/>
        <PasswordBox x:Name="PasswordBox" Grid.Row="2" Margin="0,0,0,8" Padding="8,6"/>
        <TextBlock Grid.Row="3" x:Name="ConfirmLabel" Text="Confirm password:" Margin="0,0,0,4" Foreground="{DynamicResource PrimaryForeground}"/>
        <PasswordBox x:Name="ConfirmBox" Grid.Row="4" Margin="0,0,0,16" Padding="8,6"/>
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OkBtn" Content="OK" Width="80" Height="28" Margin="0,0,8,0"
                    Click="OkBtn_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="80" Height="28"
                    Click="CancelBtn_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
