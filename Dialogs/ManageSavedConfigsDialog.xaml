<Window x:Class="WorkAudit.Dialogs.ManageSavedConfigsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Saved Report Configurations" Height="400" Width="500"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Saved configurations (drag to reorder):" Margin="0,0,0,8"/>
        <ListBox x:Name="ConfigListBox" Grid.Row="1" DisplayMemberPath="DisplayName" Margin="0,0,0,12" 
                 AllowDrop="True" SelectionChanged="ConfigListBox_SelectionChanged"
                 PreviewMouseLeftButtonDown="ConfigListBox_PreviewMouseLeftButtonDown"
                 PreviewMouseMove="ConfigListBox_PreviewMouseMove"
                 PreviewMouseLeftButtonUp="ConfigListBox_PreviewMouseLeftButtonUp"
                 DragOver="ConfigListBox_DragOver" Drop="ConfigListBox_Drop"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="FavoriteBtn" Content="★ Toggle Favorite" Width="120" Padding="12,6" Margin="0,0,8,0" Click="FavoriteBtn_Click"/>
            <Button x:Name="LoadBtn" Content="Load" Width="80" Padding="12,6" Margin="0,0,8,0" Click="LoadBtn_Click"/>
            <Button x:Name="DeleteBtn" Content="Delete" Width="80" Padding="12,6" Margin="0,0,8,0" Click="DeleteBtn_Click"/>
            <Button Content="Close" Width="80" Padding="12,6" IsCancel="True" Click="CloseBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
