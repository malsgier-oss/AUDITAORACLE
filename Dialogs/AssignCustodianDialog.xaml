<Window x:Class="WorkAudit.Dialogs.AssignCustodianDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Assign Custodian"
        Width="360" Height="180"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource ContentBackground}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Select custodian:" Margin="0,0,0,4" Foreground="{DynamicResource PrimaryForeground}"/>
        <ComboBox x:Name="CustodianCombo" Grid.Row="1" Margin="0,0,0,16" Padding="8,6"
                  DisplayMemberPath="DisplayName" MinHeight="28"/>
        <TextBlock Grid.Row="2" x:Name="InfoText" Text="" Foreground="{DynamicResource SecondaryForeground}" FontSize="12" VerticalAlignment="Top"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="ClearBtn" Content="Clear" Width="80" Height="28" Margin="0,0,8,0"
                    Click="ClearBtn_Click"/>
            <Button x:Name="OkBtn" Content="OK" Width="80" Height="28" Margin="0,0,8,0"
                    Click="OkBtn_Click" IsDefault="True"/>
            <Button x:Name="CancelBtn" Content="Cancel" Width="80" Height="28"
                    Click="CancelBtn_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
