<Window x:Class="WorkAudit.Dialogs.TextResultDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Text Result" Height="450" Width="600"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{DynamicResource ContentBackground}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock x:Name="TitleText" Text="Extracted Text" FontSize="16" FontWeight="SemiBold" 
                   Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,12"/>
        
        <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                CornerRadius="4" Background="{DynamicResource PanelBackground}">
            <TextBox x:Name="ResultTextBox" TextWrapping="Wrap" AcceptsReturn="True" 
                     IsReadOnly="False" VerticalScrollBarVisibility="Auto" 
                     Padding="8" FontSize="14" FontFamily="Consolas, Courier New"
                     Background="Transparent" Foreground="{DynamicResource PrimaryForeground}" 
                     BorderThickness="0"/>
        </Border>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="ActionBtn" Content="Accept" Padding="20,6" Margin="0,0,12,0" 
                    Background="#0E639C" Foreground="White" BorderThickness="0" Cursor="Hand" Click="Action_Click"/>
        </StackPanel>
    </Grid>
</Window>
