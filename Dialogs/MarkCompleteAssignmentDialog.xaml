<Window x:Class="WorkAudit.Dialogs.MarkCompleteAssignmentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mark Assignment Complete" Height="380" MinHeight="320" Width="450" MinWidth="400"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource ContentBackground}" Loaded="MarkCompleteAssignmentDialog_Loaded">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="DocumentNameText" Text="Document:" Margin="0,0,0,12"
                   FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryForeground}"/>

        <TextBlock Grid.Row="1" x:Name="CompletionNoteLabel" Text="Completion note (required):" Margin="0,0,0,4"
                   Foreground="{DynamicResource PrimaryForeground}"/>
        <TextBox Grid.Row="2" x:Name="ContentBox" MinHeight="80" Margin="0,0,0,12"
                 Padding="8,6" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

        <Grid Grid.Row="3" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock x:Name="TypeLabel" Text="Type:" Margin="0,0,0,4"
                           Foreground="{DynamicResource PrimaryForeground}"/>
                <ComboBox x:Name="TypeCombo" Padding="8,6"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                <TextBlock x:Name="SeverityLabel" Text="Severity:" Margin="0,0,0,4"
                           Foreground="{DynamicResource PrimaryForeground}"/>
                <ComboBox x:Name="SeverityCombo" Padding="8,6"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="OkBtn" Content="Mark Complete" Width="120" Height="32" Click="OkBtn_Click" IsDefault="True"
                    Background="#28A745" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="CancelBtn" Content="Cancel" Width="80" Height="32" Margin="12,0,0,0" Click="CancelBtn_Click" IsCancel="True"
                    Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource DimForeground}" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
