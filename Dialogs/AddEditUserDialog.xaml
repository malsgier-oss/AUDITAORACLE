<Window x:Class="WorkAudit.Dialogs.AddEditUserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add User" Height="560" MinHeight="500" Width="420" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="SingleBorderWindow"
        Background="{DynamicResource ContentBackground}">
    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0" Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Username" Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,4"/>
                    <TextBox x:Name="UsernameBox" Grid.Row="1" Padding="10,8" Height="36" Margin="0,0,0,16"/>

                    <TextBlock Grid.Row="2" Text="Display Name" Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,4"/>
                    <TextBox x:Name="DisplayNameBox" Grid.Row="3" Padding="10,8" Height="36" Margin="0,0,0,16"/>

                    <TextBlock Grid.Row="4" Text="Password" Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,4"/>
                    <Grid Grid.Row="5" Margin="0,0,0,4">
                        <PasswordBox x:Name="PasswordBox" Padding="10,8" Height="36" VerticalAlignment="Top"
                                     PasswordChanged="PasswordBox_OnPasswordChanged"/>
                        <TextBox x:Name="PasswordPlainText" Padding="10,8" Height="36" VerticalAlignment="Top"
                                 Visibility="Collapsed" TextChanged="PasswordPlainText_OnTextChanged"/>
                    </Grid>

                    <TextBlock Grid.Row="6" Text="Confirm password" Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,4"/>
                    <Grid Grid.Row="7" Margin="0,0,0,4">
                        <PasswordBox x:Name="ConfirmPasswordBox" Padding="10,8" Height="36" VerticalAlignment="Top"
                                     PasswordChanged="ConfirmPasswordBox_OnPasswordChanged"/>
                        <TextBox x:Name="ConfirmPlainText" Padding="10,8" Height="36" VerticalAlignment="Top"
                                 Visibility="Collapsed" TextChanged="ConfirmPlainText_OnTextChanged"/>
                    </Grid>

                    <CheckBox x:Name="ShowPasswordCheck" Grid.Row="8" Content="Show passwords"
                              Margin="0,0,0,8" Foreground="{DynamicResource PrimaryForeground}"
                              Checked="ShowPasswordCheck_OnChecked" Unchecked="ShowPasswordCheck_OnUnchecked"/>

                    <TextBlock x:Name="PasswordHint" Grid.Row="9" Text="Leave passwords blank to keep current"
                               Foreground="{DynamicResource SecondaryForeground}"
                               FontSize="11" Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="10" Text="Role" Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,4"/>
                    <ComboBox x:Name="RoleCombo" Grid.Row="11" Padding="10,8" Height="36" Margin="0,0,0,16"/>

                    <TextBlock Grid.Row="12" Text="Branch" Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,4"/>
                    <ComboBox x:Name="BranchCombo" Grid.Row="13" Padding="10,8" Height="36" Margin="0,0,0,0"/>
                </Grid>
            </ScrollViewer>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button x:Name="BtnOk" Content="OK" Width="80" Height="32" Margin="0,0,8,0"
                        Background="#0E639C" Foreground="White" BorderThickness="0"
                        Click="BtnOk_Click" IsDefault="True"/>
                <Button Content="Cancel" Width="80" Height="32"
                        Background="{DynamicResource ButtonSecondaryBackground}"
                        Foreground="{DynamicResource PrimaryForeground}"
                        BorderThickness="0" IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
