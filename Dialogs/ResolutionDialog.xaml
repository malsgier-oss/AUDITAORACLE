<Window x:Class="WorkAudit.Dialogs.ResolutionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Resolution Comment" Height="300" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PanelBackground}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Provide Resolution Comment" FontSize="14" FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,12"/>

        <!-- Description -->
        <TextBlock Grid.Row="1" TextWrapping="Wrap" Margin="0,0,0,12"
                   Foreground="{DynamicResource SecondaryForeground}" FontSize="11">
            Please provide a brief comment explaining how this issue was resolved. This will be visible in the note history.
        </TextBlock>

        <!-- Comment TextBox -->
        <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                Background="{DynamicResource ContentBackground}">
            <TextBox x:Name="CommentTextBox" TextWrapping="Wrap" AcceptsReturn="True"
                     BorderThickness="0" Padding="8" VerticalScrollBarVisibility="Auto"
                     Foreground="{DynamicResource PrimaryForeground}"
                     Background="Transparent"/>
        </Border>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="CancelBtn" Content="Cancel" Padding="12,6" Margin="0,0,8,0"
                    Click="CancelBtn_Click"
                    Background="{DynamicResource ButtonSecondaryBackground}"
                    Foreground="{DynamicResource PrimaryForeground}"
                    BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"/>
            <Button x:Name="ConfirmBtn" Content="Confirm Resolution" Padding="12,6"
                    Click="ConfirmBtn_Click"
                    Background="#28A745" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
