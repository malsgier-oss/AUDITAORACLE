<UserControl x:Class="WorkAudit.Views.AuditorReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid x:Name="RootGrid" Background="{DynamicResource PanelBackground}" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock x:Name="ReportsHeader" Text="My Reports" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,4"/>
                    <TextBlock x:Name="ReportsSubtitle" Text="Generate auditor reports for your branch and assignments"
                               FontSize="13" Foreground="{DynamicResource DimForeground}"/>
                </StackPanel>
            </Grid>

            <!-- Report Configuration -->
            <Border Grid.Row="1" Background="{DynamicResource ContentBackground}" Padding="20" Margin="0,0,0,16"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="Report Configuration" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" x:Name="PeriodLabel" Text="Period:" VerticalAlignment="Center"
                                   Margin="0,0,12,0" Foreground="{DynamicResource PrimaryForeground}"/>
                        <ComboBox x:Name="PeriodCombo" Grid.Row="0" Grid.Column="1" Width="200" HorizontalAlignment="Left"
                                  SelectionChanged="PeriodCombo_SelectionChanged"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Date Range:" VerticalAlignment="Center"
                                   Margin="0,0,12,0" Foreground="{DynamicResource PrimaryForeground}"/>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                            <DatePicker x:Name="DateFromPicker" Width="120" Margin="0,0,8,0" SelectedDateChanged="DateRange_Changed"/>
                            <TextBlock Text="to" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource SecondaryForeground}"/>
                            <DatePicker x:Name="DateToPicker" Width="120" SelectedDateChanged="DateRange_Changed"/>
                        </StackPanel>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Report Type:" VerticalAlignment="Center"
                                   Margin="0,0,12,0" Foreground="{DynamicResource PrimaryForeground}"/>
                        <StackPanel Grid.Row="4" Grid.Column="1">
                            <RadioButton x:Name="RbBranchSummary" Content="Branch Summary" Margin="0,2" GroupName="ReportType" IsChecked="True"/>
                            <RadioButton x:Name="RbSectionSummary" Content="Section Summary" Margin="0,2" GroupName="ReportType"/>
                            <RadioButton x:Name="RbStatusSummary" Content="Status Summary" Margin="0,2" GroupName="ReportType"/>
                            <RadioButton x:Name="RbAssignmentSummary" Content="Assignment Summary" Margin="0,2" GroupName="ReportType"/>
                            <RadioButton x:Name="RbAuditTrail" Content="Audit Trail" Margin="0,2" GroupName="ReportType"/>
                            <RadioButton x:Name="RbDailySummary" Content="Daily Summary" Margin="0,2" GroupName="ReportType"/>
                        </StackPanel>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Format:" VerticalAlignment="Center"
                                   Margin="0,0,12,0" Foreground="{DynamicResource PrimaryForeground}"/>
                        <ComboBox x:Name="FormatCombo" Grid.Row="6" Grid.Column="1" Width="120" HorizontalAlignment="Left"/>

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Branch:" VerticalAlignment="Center"
                                   Margin="0,0,12,0" Foreground="{DynamicResource PrimaryForeground}"/>
                        <ComboBox x:Name="BranchCombo" Grid.Row="8" Grid.Column="1" Width="200" HorizontalAlignment="Left"/>

                        <TextBlock Grid.Row="10" Grid.Column="0" Text="Section:" VerticalAlignment="Center"
                                   Margin="0,0,12,0" Foreground="{DynamicResource PrimaryForeground}"/>
                        <ComboBox x:Name="SectionCombo" Grid.Row="10" Grid.Column="1" Width="200" HorizontalAlignment="Left"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Generate buttons and message -->
            <Border Grid.Row="2" Background="{DynamicResource ContentBackground}" Padding="20" Margin="0,0,0,16"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                <StackPanel>
                    <TextBlock x:Name="MessageText" Text="" FontSize="13" Margin="0,0,0,12" TextWrapping="Wrap"/>
                    <ProgressBar x:Name="ProgressBar" Height="4" Margin="0,0,0,12" Visibility="Collapsed"
                                 Minimum="0" Maximum="100" Value="0"/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="GeneratePdfBtn" Content="Generate PDF" Padding="16,10" Margin="0,0,12,0"
                                Background="#DC3545" Foreground="White" BorderThickness="0" Cursor="Hand"
                                Click="GeneratePdfBtn_Click" ToolTip="Generate report as PDF"/>
                        <Button x:Name="GenerateExcelBtn" Content="Generate Excel" Padding="16,10" Margin="0,0,12,0"
                                Background="#28A745" Foreground="White" BorderThickness="0" Cursor="Hand"
                                Click="GenerateExcelBtn_Click" ToolTip="Generate report as Excel"/>
                        <Button x:Name="GenerateCsvBtn" Content="Generate CSV" Padding="16,10"
                                Background="#17A2B8" Foreground="White" BorderThickness="0" Cursor="Hand"
                                Click="GenerateCsvBtn_Click" ToolTip="Generate report as CSV (Branch/Section/Status/Daily Summary only)"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- My drafts (same Report Editor as full Reports view) -->
            <Border x:Name="DraftsSection" Grid.Row="3" Background="{DynamicResource ContentBackground}" Padding="20" Margin="0,0,0,16"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="My report drafts" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,8"/>
                    <TextBlock Text="Drafts you created from Reports (manager view) or elsewhere. Select one and open it in the editor."
                               FontSize="12" Foreground="{DynamicResource DimForeground}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    <ListBox x:Name="DraftsList" Height="140" SelectionChanged="DraftsList_SelectionChanged"
                             MouseDoubleClick="DraftsList_MouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayText}" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button x:Name="OpenDraftInEditorBtn" Content="Open in editor" Padding="12,8" Margin="0,8,0,0"
                            HorizontalAlignment="Left" Background="#6F42C1" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Click="OpenDraftInEditorBtn_Click" IsEnabled="False"
                            ToolTip="Opens the Report Editor for the selected draft"/>
                </StackPanel>
            </Border>

            <!-- Report History (optional) -->
            <Border Grid.Row="4" Background="{DynamicResource ContentBackground}" Padding="20"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="Recent Reports" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,12"/>
                    <ListBox x:Name="ReportHistoryList" Height="180" SelectionChanged="ReportHistoryList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayText}" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
