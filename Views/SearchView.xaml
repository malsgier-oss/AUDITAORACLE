<UserControl x:Class="WorkAudit.Views.SearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="FilterLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryForeground}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </UserControl.Resources>
    <Grid Background="{DynamicResource PanelBackground}" Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Filters row -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{DynamicResource ContentBackground}" Padding="12" Margin="0,0,0,8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Branch" Style="{StaticResource FilterLabel}"/>
                <ComboBox x:Name="BranchFilter" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,8,0" MinWidth="120"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Section" Style="{StaticResource FilterLabel}"/>
                <ComboBox x:Name="SectionFilter" Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Margin="0,0,8,0" MinWidth="120"/>

                <TextBlock Grid.Row="0" Grid.Column="4" Text="Type" Style="{StaticResource FilterLabel}"/>
                <ComboBox x:Name="TypeFilter" Grid.Row="1" Grid.Column="4" Grid.ColumnSpan="2" Margin="0,0,8,0" MinWidth="130"/>

                <TextBlock Grid.Row="0" Grid.Column="6" Text="Status" Style="{StaticResource FilterLabel}"/>
                <ComboBox x:Name="StatusFilter" Grid.Row="1" Grid.Column="6" Grid.ColumnSpan="2" Margin="0,0,8,0" MinWidth="120"/>

                <TextBlock Grid.Row="0" Grid.Column="8" Text="From" Style="{StaticResource FilterLabel}"/>
                <DatePicker x:Name="DateFromFilter" Grid.Row="1" Grid.Column="8" Grid.ColumnSpan="2" Margin="0,0,8,0" MinWidth="120"/>

                <TextBlock Grid.Row="0" Grid.Column="10" Text="To" Style="{StaticResource FilterLabel}"/>
                <DatePicker x:Name="DateToFilter" Grid.Row="1" Grid.Column="10" Grid.ColumnSpan="2" Margin="0,0,8,0" MinWidth="120"/>

                <TextBlock Grid.Row="0" Grid.Column="12" Text="Text Search" Style="{StaticResource FilterLabel}"/>
                <TextBox x:Name="SearchBox" Grid.Row="1" Grid.Column="12" Margin="0,0,8,0" Padding="8,6" Height="28"
                         VerticalContentAlignment="Center" Background="{DynamicResource ContentBackground}" Foreground="{DynamicResource DimForeground}"
                         KeyDown="SearchBox_KeyDown"/>
                <StackPanel Grid.Row="1" Grid.Column="13" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox x:Name="UseFtsCheck" Content="FTS" ToolTip="Full-text search" Margin="0,0,12,0"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.ColumnSpan="16" Orientation="Horizontal" Margin="0,4,0,0">
                    <Button x:Name="SearchBtn" Content="Search" Padding="16,6" Margin="0,0,8,0" Click="SearchBtn_Click" Background="#0E639C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="ClearBtn" Content="Clear" Padding="16,6" Margin="0,0,8,0" Click="ClearBtn_Click" Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="SaveSearchBtn" Content="Save Search" Padding="16,6" Margin="0,0,8,0" Click="SaveSearchBtn_Click" Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand"/>
                    <ComboBox x:Name="SavedSearchesCombo" MinWidth="120" Margin="0,0,8,0" SelectionChanged="SavedSearchesCombo_SelectionChanged"
                              ToolTip="Load saved search"/>
                    <Button x:Name="ExportBtn" Content="Export" Padding="16,6" Margin="0,0,8,0" Click="ExportBtn_Click" Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Results grid -->
        <StackPanel Grid.Row="1" Grid.Column="0">
            <TextBlock x:Name="ResultCountText" Text="" Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,8" FontSize="12"/>
            <DataGrid x:Name="ResultsGrid" Height="400" AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Extended" SelectionChanged="ResultsGrid_SelectionChanged"
                      Background="{DynamicResource ContentBackground}" RowBackground="{DynamicResource ContentBackground}" AlternatingRowBackground="{DynamicResource AlternateRowBackground}"
                      BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                      HeadersVisibility="Column" CanUserAddRows="False" CanUserDeleteRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding DocumentType}" Width="*"/>
                    <DataGridTextColumn Header="Confidence" Binding="{Binding ClassificationConfidence, StringFormat=P0}" Width="70"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding ExtractedDate}" Width="100"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                    <DataGridTextColumn Header="Section" Binding="{Binding Section}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock x:Name="BulkActionLabel" Text="Use Ctrl+Click / Shift+Click for multi-select" Foreground="{DynamicResource SecondaryForeground}" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button x:Name="BulkStatusBtn" Content="Set Status..." Padding="12,6" Margin="0,0,8,0" Click="BulkStatusBtn_Click" Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="AssignBtn" Content="Assign..." Padding="12,6" Margin="0,0,8,0" Click="AssignBtn_Click" Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand"
                        ToolTip="Assign selected documents to a user (Manager+ only)"/>
                <Button x:Name="ChangeTypeBtn" Content="Change type..." Padding="12,6" Margin="0,0,8,0" Click="ChangeTypeBtn_Click" Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand"
                        ToolTip="Override document type (single selection)."/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource ContentBackground}" Margin="8,0,0,0" Padding="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Properties" Foreground="{DynamicResource PrimaryForeground}" FontWeight="Bold" Margin="0,0,0,8"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="DetailText" Foreground="{DynamicResource SecondaryForeground}" TextWrapping="Wrap" LineHeight="18" FontSize="12"
                                   Text="Select a document to view details. Use Ctrl+Click or Shift+Click for multi-select and bulk actions."/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
