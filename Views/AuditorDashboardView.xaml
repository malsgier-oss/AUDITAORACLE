<UserControl x:Class="WorkAudit.Views.AuditorDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:WorkAudit.Views">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid x:Name="RootGrid" Background="{DynamicResource PanelBackground}" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Alerts Section -->
                <RowDefinition Height="Auto"/> <!-- Personal KPIs -->
                <RowDefinition Height="Auto"/> <!-- Hybrid View: Assignments + Branch -->
                <RowDefinition Height="Auto"/> <!-- Critical Issues & Follow-ups -->
                <RowDefinition Height="Auto"/> <!-- Branch KPI & Trends -->
                <RowDefinition Height="Auto"/> <!-- Daily Journal -->
                <RowDefinition Height="Auto"/> <!-- Recent Activity Feed -->
                <RowDefinition Height="Auto"/> <!-- Quick Actions -->
                <RowDefinition Height="*"/>    <!-- Flexible space -->
            </Grid.RowDefinitions>

            <!-- Header with Refresh -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="DashboardHeader" Text="Auditor Dashboard" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,4"/>
                    <TextBlock x:Name="DashboardSubtitle" Text="Your personal work center and branch overview"
                               FontSize="13" Foreground="{DynamicResource DimForeground}"/>
                </StackPanel>
                <Button x:Name="RefreshBtn" Grid.Column="1" Content="🔄 Refresh" Padding="12,8"
                        Background="#17A2B8" Foreground="White" BorderThickness="0" Cursor="Hand" Click="RefreshBtn_Click"
                        ToolTip="Refresh dashboard data" FontWeight="SemiBold"/>
            </Grid>

            <!-- Smart Alerts Section -->
            <Border Grid.Row="1" x:Name="AlertsPanel" Background="#FFF3CD" BorderBrush="#FFC107" BorderThickness="1"
                    Padding="16" Margin="0,0,0,16" CornerRadius="4" Visibility="Collapsed">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="⚠️ Alerts &amp; Notifications" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#856404" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Dismiss All" Padding="8,4"
                                Background="Transparent" Foreground="#856404" BorderBrush="#856404" BorderThickness="1"
                                Cursor="Hand" Click="DismissAlerts_Click"/>
                    </Grid>
                    <ItemsControl x:Name="AlertsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" BorderBrush="#FFC107" BorderThickness="1" CornerRadius="3"
                                        Padding="10,8" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Message}" TextWrapping="Wrap"
                                                   Foreground="#856404" VerticalAlignment="Center"/>
                                        <Button Grid.Column="2" Content="View" Padding="6,3" Margin="8,0,0,0"
                                                Background="#FFC107" Foreground="White" BorderThickness="0" Cursor="Hand"
                                                Click="ViewAlert_Click" Tag="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Personal KPI Cards -->
            <Border Grid.Row="2" Background="{DynamicResource ContentBackground}" Padding="20" Margin="0,0,0,16"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="📊 My Performance" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- KPI Card 1: Pending -->
                        <Border Grid.Column="0" Background="{DynamicResource PanelBackground}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                                Padding="16" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="📋 My Pending" FontSize="12" Foreground="{DynamicResource DimForeground}" Margin="0,0,0,8"/>
                                <TextBlock x:Name="KpiMyPending" Text="0" FontSize="28" FontWeight="Bold"
                                           Foreground="#FFC107" Margin="0,0,0,4"/>
                                <TextBlock x:Name="KpiMyPendingChange" Text="Assignments" FontSize="11"
                                           Foreground="{DynamicResource DimForeground}"/>
                            </StackPanel>
                        </Border>

                        <!-- KPI Card 2: In Progress -->
                        <Border Grid.Column="1" Background="{DynamicResource PanelBackground}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                                Padding="16" Margin="3,0">
                            <StackPanel>
                                <TextBlock Text="⚡ In Progress" FontSize="12" Foreground="{DynamicResource DimForeground}" Margin="0,0,0,8"/>
                                <TextBlock x:Name="KpiMyInProgress" Text="0" FontSize="28" FontWeight="Bold"
                                           Foreground="#17A2B8" Margin="0,0,0,4"/>
                                <TextBlock x:Name="KpiMyInProgressChange" Text="Active" FontSize="11"
                                           Foreground="{DynamicResource DimForeground}"/>
                            </StackPanel>
                        </Border>

                        <!-- KPI Card 3: Completion Rate -->
                        <Border Grid.Column="2" Background="{DynamicResource PanelBackground}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                                Padding="16" Margin="3,0">
                            <StackPanel>
                                <TextBlock Text="✅ Completion Rate" FontSize="12" Foreground="{DynamicResource DimForeground}" Margin="0,0,0,8"/>
                                <TextBlock x:Name="KpiMyCompletionRate" Text="0%" FontSize="28" FontWeight="Bold"
                                           Foreground="#28A745" Margin="0,0,0,4"/>
                                <TextBlock x:Name="KpiMyCompletionRateChange" Text="This month" FontSize="11"
                                           Foreground="{DynamicResource DimForeground}"/>
                            </StackPanel>
                        </Border>

                        <!-- KPI Card 4: Avg Time -->
                        <Border Grid.Column="3" Background="{DynamicResource PanelBackground}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                                Padding="16" Margin="6,0,0,0">
                            <StackPanel>
                                <TextBlock Text="⏱️ Avg Time" FontSize="12" Foreground="{DynamicResource DimForeground}" Margin="0,0,0,8"/>
                                <TextBlock x:Name="KpiMyAvgTime" Text="—" FontSize="28" FontWeight="Bold"
                                           Foreground="#6C757D" Margin="0,0,0,4"/>
                                <TextBlock x:Name="KpiMyAvgTimeChange" Text="Per assignment" FontSize="11"
                                           Foreground="{DynamicResource DimForeground}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    <views:TeamTasksPanel x:Name="TeamTasksSection"/>
                </StackPanel>
            </Border>

            <!-- Hybrid View: My Assignments + Branch Overview -->
            <Grid Grid.Row="3" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: My Assignments -->
                <Border Grid.Column="0" Background="{DynamicResource ContentBackground}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="20">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📋 My Assignments" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryForeground}" VerticalAlignment="Center"/>
                            <ComboBox x:Name="AssignmentFilterCombo" Grid.Column="1" Width="120"
                                      SelectionChanged="AssignmentFilterCombo_Changed"/>
                        </Grid>

                        <DataGrid x:Name="AssignmentsGrid" Height="280" AutoGenerateColumns="False"
                                  IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                                  SelectionMode="Single" GridLinesVisibility="None"
                                  HeadersVisibility="Column" BorderThickness="0"
                                  Background="{DynamicResource PanelBackground}"
                                  RowBackground="{DynamicResource PanelBackground}"
                                  AlternatingRowBackground="{DynamicResource ContentBackground}"
                                  MouseDoubleClick="AssignmentsGrid_DoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Priority" Binding="{Binding PriorityIcon}" Width="60"/>
                                <DataGridTextColumn Header="Document" Binding="{Binding DocumentRef}" Width="*"/>
                                <DataGridTextColumn Header="Due Date" Binding="{Binding DueDateDisplay}" Width="100"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding StatusBadge}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                            <Button x:Name="BtnStartReview" Content="Start Review" Padding="10,6" Margin="0,0,8,0"
                                    Background="#17A2B8" Foreground="White" BorderThickness="0" Cursor="Hand"
                                    Click="BtnStartReview_Click" ToolTip="Start working on selected assignment"/>
                            <Button x:Name="BtnMarkComplete" Content="Mark Complete" Padding="10,6" Margin="0,0,8,0"
                                    Background="#28A745" Foreground="White" BorderThickness="0" Cursor="Hand"
                                    Click="BtnMarkComplete_Click" ToolTip="Mark selected assignment as complete"/>
                            <Button x:Name="BtnViewDocument" Content="View Document" Padding="10,6"
                                    Background="#6C757D" Foreground="White" BorderThickness="0" Cursor="Hand"
                                    Click="BtnViewDocument_Click" ToolTip="Open document in Workspace"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Right: Branch Overview -->
                <Border Grid.Column="2" Background="{DynamicResource ContentBackground}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="20">
                    <StackPanel>
                        <TextBlock Text="📍 Branch Overview" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,12"/>

                        <!-- Branch Stats -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource PanelBackground}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3"
                                    Padding="10" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="Total Docs" FontSize="11" Foreground="{DynamicResource DimForeground}"/>
                                    <TextBlock x:Name="BranchTotalDocs" Text="0" FontSize="20" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryForeground}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="1" Background="{DynamicResource PanelBackground}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3"
                                    Padding="10" Margin="4,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Pending" FontSize="11" Foreground="{DynamicResource DimForeground}"/>
                                    <TextBlock x:Name="BranchPendingDocs" Text="0" FontSize="20" FontWeight="Bold"
                                               Foreground="#FFC107"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Grid.Column="0" Background="{DynamicResource PanelBackground}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3"
                                    Padding="10" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="Issues" FontSize="11" Foreground="{DynamicResource DimForeground}"/>
                                    <TextBlock x:Name="BranchIssues" Text="0" FontSize="20" FontWeight="Bold"
                                               Foreground="#DC3545"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Grid.Column="1" Background="{DynamicResource PanelBackground}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3"
                                    Padding="10" Margin="4,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Cleared" FontSize="11" Foreground="{DynamicResource DimForeground}"/>
                                    <TextBlock x:Name="BranchCleared" Text="0" FontSize="20" FontWeight="Bold"
                                               Foreground="#28A745"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Recent Documents List -->
                        <TextBlock Text="Recent Documents" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryForeground}" Margin="0,8,0,8"/>

                        <DataGrid x:Name="BranchDocsGrid" Height="160" AutoGenerateColumns="False"
                                  IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                                  SelectionMode="Single" GridLinesVisibility="None"
                                  HeadersVisibility="Column" BorderThickness="0"
                                  Background="{DynamicResource PanelBackground}"
                                  RowBackground="{DynamicResource PanelBackground}"
                                  AlternatingRowBackground="{DynamicResource ContentBackground}"
                                  MouseDoubleClick="BranchDocsGrid_DoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Status" Binding="{Binding StatusIcon}" Width="50"/>
                                <DataGridTextColumn Header="Document" Binding="{Binding DocumentRef}" Width="*"/>
                                <DataGridTextColumn Header="Updated" Binding="{Binding UpdatedDisplay}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Critical Issues & Follow-ups -->
            <Border Grid.Row="4" Background="{DynamicResource ContentBackground}" Padding="20" Margin="0,0,0,16"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="⚠️ Critical Issues &amp; Follow-ups" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryForeground}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="IssuesFilterCombo" Grid.Column="1" Width="150"
                                  SelectionChanged="IssuesFilterCombo_Changed"/>
                    </Grid>

                    <DataGrid x:Name="IssuesGrid" Height="180" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                              SelectionMode="Single" GridLinesVisibility="None"
                              HeadersVisibility="Column" BorderThickness="0"
                              Background="{DynamicResource PanelBackground}"
                              RowBackground="{DynamicResource PanelBackground}"
                              AlternatingRowBackground="{DynamicResource ContentBackground}"
                              MouseDoubleClick="IssuesGrid_DoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Severity" Binding="{Binding SeverityDisplay}" Width="90"/>
                            <DataGridTextColumn Header="Document" Binding="{Binding DocumentRef}" Width="*"/>
                            <DataGridTextColumn Header="Issue" Binding="{Binding IssuePreview}" Width="200"/>
                            <DataGridTextColumn Header="Assigned To" Binding="{Binding AssignedTo}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button x:Name="BtnViewIssue" Content="View" Padding="10,6" Margin="0,0,8,0"
                                Background="#17A2B8" Foreground="White" BorderThickness="0" Cursor="Hand"
                                Click="BtnViewIssue_Click" ToolTip="View issue details"/>
                        <Button x:Name="BtnAddNote" Content="Add Note" Padding="10,6" Margin="0,0,8,0"
                                Background="#6C757D" Foreground="White" BorderThickness="0" Cursor="Hand"
                                Click="BtnAddNote_Click" ToolTip="Add note to document"/>
                        <Button x:Name="BtnMarkResolved" Content="Mark Resolved" Padding="10,6"
                                Background="#28A745" Foreground="White" BorderThickness="0" Cursor="Hand"
                                Click="BtnMarkResolved_Click" ToolTip="Mark issue as resolved"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Branch KPI & Trends (7-day) -->
            <Border Grid.Row="5" Background="{DynamicResource ContentBackground}" Padding="20" Margin="0,0,0,16"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="📈 Branch Performance (Last 7 Days)" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Trend 1: Docs Processed -->
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Documents Cleared" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,8"/>
                            <ItemsControl x:Name="TrendDocsProcessed">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="20" Height="{Binding BarHeight}" Background="#28A745"
                                                Margin="2,0" VerticalAlignment="Bottom"
                                                ToolTip="{Binding Tooltip}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="TrendDocsProcessedTotal" Text="0 total" FontSize="11" TextAlignment="Center"
                                       Foreground="{DynamicResource DimForeground}" Margin="0,8,0,0"/>
                        </StackPanel>

                        <!-- Trend 2: Issues Found -->
                        <StackPanel Grid.Column="1" Margin="4,0">
                            <TextBlock Text="Issues Found" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,8"/>
                            <ItemsControl x:Name="TrendIssuesFound">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="20" Height="{Binding BarHeight}" Background="#DC3545"
                                                Margin="2,0" VerticalAlignment="Bottom"
                                                ToolTip="{Binding Tooltip}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="TrendIssuesFoundTotal" Text="0 total" FontSize="11" TextAlignment="Center"
                                       Foreground="{DynamicResource DimForeground}" Margin="0,8,0,0"/>
                        </StackPanel>

                        <!-- Trend 3: Pending Review -->
                        <StackPanel Grid.Column="2" Margin="4,0">
                            <TextBlock Text="Pending Review" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,8"/>
                            <ItemsControl x:Name="TrendPendingReview">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="20" Height="{Binding BarHeight}" Background="#FFC107"
                                                Margin="2,0" VerticalAlignment="Bottom"
                                                ToolTip="{Binding Tooltip}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="TrendPendingReviewTotal" Text="0 avg" FontSize="11" TextAlignment="Center"
                                       Foreground="{DynamicResource DimForeground}" Margin="0,8,0,0"/>
                        </StackPanel>

                        <!-- Trend 4: Completion Rate -->
                        <StackPanel Grid.Column="3" Margin="8,0,0,0">
                            <TextBlock Text="Completion Rate" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,8"/>
                            <ItemsControl x:Name="TrendCompletionRate">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="20" Height="{Binding BarHeight}" Background="#17A2B8"
                                                Margin="2,0" VerticalAlignment="Bottom"
                                                ToolTip="{Binding Tooltip}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="TrendCompletionRateTotal" Text="0% avg" FontSize="11" TextAlignment="Center"
                                       Foreground="{DynamicResource DimForeground}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Daily Journal -->
            <Border Grid.Row="6" Background="{DynamicResource ContentBackground}" Padding="20" Margin="0,0,0,16"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="JournalHeader" Text="📝 Daily Journal - Today" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryForeground}" VerticalAlignment="Center"/>
                        <Button x:Name="BtnViewJournalHistory" Grid.Column="1" Content="View History" Padding="10,6"
                                Background="#6C757D" Foreground="White" BorderThickness="0" Cursor="Hand"
                                Click="BtnViewJournalHistory_Click" ToolTip="View past journal entries"/>
                    </Grid>

                    <TextBlock Text="Notes and observations for today (auto-saves)" FontSize="11"
                               Foreground="{DynamicResource DimForeground}" Margin="0,0,0,8"/>

                    <TextBox x:Name="JournalTextBox" Height="100" TextWrapping="Wrap" AcceptsReturn="True"
                             Padding="8,6" VerticalScrollBarVisibility="Auto"
                             LostFocus="JournalTextBox_LostFocus"
                             ToolTip="Your personal notes for today - saved automatically"/>

                    <TextBlock x:Name="JournalSaveStatus" Text="Auto-saved" FontSize="10"
                               Foreground="{DynamicResource DimForeground}" Margin="0,4,0,0"
                               HorizontalAlignment="Right" Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- Recent Activity Feed -->
            <Border Grid.Row="7" Background="{DynamicResource ContentBackground}" Padding="20" Margin="0,0,0,16"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="🕒 My Recent Activity (Last 24 Hours)" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,12"/>

                    <ScrollViewer Height="180" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ActivityFeedList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1" Padding="10,8" Cursor="Hand"
                                            MouseLeftButtonUp="ActivityFeedItem_Click" Tag="{Binding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="14" Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Description}" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource PrimaryForeground}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding RelativeTime}" FontSize="11"
                                                       Foreground="{DynamicResource DimForeground}" VerticalAlignment="Top"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- Quick Actions -->
            <Border Grid.Row="8" Background="{DynamicResource ContentBackground}" Padding="20" Margin="0,0,0,16"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="⚡ Quick Actions" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,12"/>

                    <UniformGrid Rows="2" Columns="3">
                        <Button Content="🔍 Advanced Search" Margin="4" Padding="12,16" FontSize="13"
                                Background="{DynamicResource PanelBackground}" Foreground="{DynamicResource PrimaryForeground}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Cursor="Hand"
                                Click="BtnQuickSearch_Click" ToolTip="Search documents"/>
                        <Button Content="📊 Generate My Report" Margin="4" Padding="12,16" FontSize="13"
                                Background="{DynamicResource PanelBackground}" Foreground="{DynamicResource PrimaryForeground}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Cursor="Hand"
                                Click="BtnQuickReport_Click" ToolTip="Generate Auditor report"/>
                        <Button Content="📂 Go to Workspace" Margin="4" Padding="12,16" FontSize="13"
                                Background="{DynamicResource PanelBackground}" Foreground="{DynamicResource PrimaryForeground}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Cursor="Hand"
                                Click="BtnQuickWorkspace_Click" ToolTip="Open Workspace view"/>
                        <Button Content="📝 Add New Note" Margin="4" Padding="12,16" FontSize="13"
                                Background="{DynamicResource PanelBackground}" Foreground="{DynamicResource PrimaryForeground}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Cursor="Hand"
                                Click="BtnQuickAddNote_Click" ToolTip="Add note to current document"/>
                        <Button Content="✅ My Completed Work" Margin="4" Padding="12,16" FontSize="13"
                                Background="{DynamicResource PanelBackground}" Foreground="{DynamicResource PrimaryForeground}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Cursor="Hand"
                                Click="BtnQuickCompleted_Click" ToolTip="View completed assignments"/>
                        <Button Content="📧 View Notifications" Margin="4" Padding="12,16" FontSize="13"
                                Background="{DynamicResource PanelBackground}" Foreground="{DynamicResource PrimaryForeground}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Cursor="Hand"
                                Click="BtnQuickNotifications_Click" ToolTip="View all notifications"/>
                    </UniformGrid>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>
