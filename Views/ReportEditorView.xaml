<UserControl x:Class="WorkAudit.Views.ReportEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">
    <Grid Background="{DynamicResource PanelBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource ContentBackground}" Padding="20" Margin="16,16,16,0"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6,6,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="📝 Report Editor" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,4"/>
                    <TextBlock x:Name="SubtitleText" Text="Edit report content before final export" FontSize="13"
                               Foreground="{DynamicResource DimForeground}"/>
                </StackPanel>
                <Button Grid.Column="1" Content="✖ Close" Padding="12,8" Background="#6C757D" Foreground="White"
                        BorderThickness="0" Cursor="Hand" Click="CloseBtn_Click" FontSize="13"/>
            </Grid>
        </Border>

        <!-- Metadata Panel -->
        <Border Grid.Row="1" Background="{DynamicResource ContentBackground}" Padding="20" Margin="16,0,16,0"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,1,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="Title" FontSize="12" Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TitleTextBox" Padding="8" FontSize="13"/>
                </StackPanel>

                <!-- Tags -->
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="12,0,0,0">
                    <TextBlock Text="Tags (comma-separated)" FontSize="12" Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TagsTextBox" Padding="8" FontSize="13"/>
                </StackPanel>

                <!-- Notes -->
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
                    <TextBlock Text="Notes" FontSize="12" Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,4"/>
                    <TextBox x:Name="NotesTextBox" Padding="8" FontSize="13" Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"/>
                </StackPanel>

                <!-- Status Info -->
                <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal">
                    <TextBlock x:Name="StatusText" FontSize="12" Foreground="{DynamicResource SecondaryForeground}"/>
                    <CheckBox x:Name="FinalizedCheckBox" Content="Mark as finalized" Margin="20,0,0,0" FontSize="12"
                              ToolTip="Mark this draft as ready for export"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Editor Content -->
        <Border Grid.Row="2" Background="{DynamicResource ContentBackground}" Margin="16,16,16,0"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
            <Grid>
                <wpf:WebView2 x:Name="EditorWebView" />
                <TextBlock x:Name="LoadingText" Text="Loading editor..." FontSize="14" 
                           Foreground="{DynamicResource SecondaryForeground}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Action Bar -->
        <Border Grid.Row="3" Background="{DynamicResource ContentBackground}" Padding="20" Margin="16,16,16,16"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Info -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="MessageText" FontSize="13" Foreground="{DynamicResource PrimaryForeground}"/>
                </StackPanel>

                <!-- Right: Actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="SaveBtn" Content="💾 Save Draft" Padding="14,10" Margin="0,0,12,0"
                            Background="#17A2B8" Foreground="White" BorderThickness="0" Cursor="Hand" Click="SaveBtn_Click"
                            FontSize="13" FontWeight="SemiBold" MinWidth="120"/>
                    <Button x:Name="ExportPdfBtn" Content="📄 Export PDF" Padding="14,10" Margin="0,0,12,0"
                            Background="#007BFF" Foreground="White" BorderThickness="0" Cursor="Hand" Click="ExportPdfBtn_Click"
                            FontSize="13" FontWeight="SemiBold" MinWidth="120"/>
                    <Button x:Name="ExportExcelBtn" Content="📊 Export Excel" Padding="14,10" Margin="0,0,12,0"
                            Background="#28A745" Foreground="White" BorderThickness="0" Cursor="Hand" Click="ExportExcelBtn_Click"
                            FontSize="13" FontWeight="SemiBold" MinWidth="130"/>
                    <Button x:Name="DeleteBtn" Content="🗑️ Delete" Padding="14,10"
                            Background="#DC3545" Foreground="White" BorderThickness="0" Cursor="Hand" Click="DeleteBtn_Click"
                            FontSize="13" FontWeight="SemiBold" MinWidth="100"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
