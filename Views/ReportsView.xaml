<UserControl x:Class="WorkAudit.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:WorkAudit.Views">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid x:Name="RootGrid" Background="{DynamicResource PanelBackground}" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- KPI Cards -->
                <RowDefinition Height="Auto"/> <!-- Executive Summary Card -->
                <RowDefinition Height="Auto"/> <!-- Smart Recommendations Card -->
                <RowDefinition Height="Auto"/> <!-- Auditor daily journals (Manager/Admin) -->
                <RowDefinition Height="Auto"/> <!-- Report Configuration Section Header -->
                <RowDefinition Height="Auto"/> <!-- Report Configuration Cards Grid -->
                <RowDefinition Height="Auto"/> <!-- Export Actions Bar -->
                <RowDefinition Height="Auto"/> <!-- Recent Reports -->
                <RowDefinition Height="Auto"/> <!-- Executive Dashboard (when selected) -->
                <RowDefinition Height="Auto"/> <!-- Attestation Panel -->
                <RowDefinition Height="*"/>    <!-- Flexible space -->
            </Grid.RowDefinitions>

            <!-- ========== HEADER SECTION (aligned with Admin Dashboard toolbar) ========== -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="ReportsHeader" Text="Reports &amp; Intelligence" FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,4"/>
                        <TextBlock x:Name="ReportsSubtitle" Text="Generate reports and analyze document intelligence" FontSize="13"
                                   Foreground="{DynamicResource DimForeground}"/>
                    </StackPanel>
                    <Button x:Name="RefreshDashboardBtn" Grid.Column="1" Content="🔄 Refresh" Padding="12,8" Margin="0,0,12,0"
                            Background="#17A2B8" Foreground="White" BorderThickness="0" Cursor="Hand" Click="RefreshDashboardBtn_Click"
                            ToolTip="Refresh dashboard data" FontWeight="SemiBold"/>
                    <ComboBox x:Name="TimeRangeCombo" Grid.Column="2" MinWidth="190" MaxWidth="240"
                              SelectionChanged="TimeRangeCombo_Changed"
                              ToolTip="Select time range for intelligence metrics"/>
                </Grid>
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Branch" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{DynamicResource DimForeground}"/>
                    <ComboBox x:Name="ToolbarBranchCombo" Width="200" Margin="0,0,16,0"
                              SelectionChanged="ToolbarScopeFilter_Changed"
                              ToolTip="Limit KPIs and intelligence to a branch ((All) = no filter)"/>
                    <TextBlock Text="Section" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{DynamicResource DimForeground}"/>
                    <ComboBox x:Name="ToolbarSectionCombo" Width="180"
                              SelectionChanged="ToolbarScopeFilter_Changed"
                              ToolTip="Limit KPIs and intelligence to a section ((All) = no filter)"/>
                </StackPanel>
            </Grid>

            <!-- ========== KPI CARDS SECTION ========== -->
            <Border Grid.Row="1" Background="{DynamicResource ContentBackground}" Padding="20" Margin="0,0,0,16"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                <StackPanel>
                    <TextBlock x:Name="KpiHeaderText" Text="Key Performance Indicators" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,16"/>
                    <Grid x:Name="KpiCardsContainer">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- KPI cards will be dynamically populated in code-behind -->
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ========== EXECUTIVE SUMMARY CARD ========== -->
            <Border Grid.Row="2" Background="{DynamicResource ContentBackground}" Padding="20" Margin="0,0,0,16"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="📊 Executive Summary" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,12"/>
                    <TextBlock x:Name="AutoSummaryText" TextWrapping="Wrap" Foreground="{DynamicResource PrimaryForeground}"
                               LineHeight="22" FontSize="13"/>
                </StackPanel>
            </Border>

            <!-- ========== SMART RECOMMENDATIONS CARD ========== -->
            <Border Grid.Row="3" Background="{DynamicResource ContentBackground}" Padding="20" Margin="0,0,0,16"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="💡 Smart Recommendations" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,12"/>
                    <ItemsControl x:Name="RecommendationsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10" Margin="0,0,0,10" Background="{DynamicResource PanelBackground}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="{DynamicResource PrimaryForeground}"
                                               FontSize="13" LineHeight="20"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ========== AUDITOR DAILY JOURNALS (Manager / Administrator) ========== -->
            <Border x:Name="JournalViewerPanel" Grid.Row="4" Visibility="Collapsed" Margin="0,0,0,16"
                    Background="{DynamicResource ContentBackground}" Padding="20"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                <StackPanel>
                    <TextBlock x:Name="JournalViewerTitle" Text="Auditor daily journals" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,4"/>
                    <TextBlock x:Name="JournalViewerSubtitle" Text="Read-only. Select a user and date, then Load."
                               FontSize="12" Foreground="{DynamicResource DimForeground}" Margin="0,0,0,12" TextWrapping="Wrap"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="JournalUserLabel" Grid.Column="0" Text="User:" VerticalAlignment="Center"
                                   Margin="0,0,8,0" Foreground="{DynamicResource PrimaryForeground}"/>
                        <ComboBox x:Name="JournalUserCombo" Grid.Column="1" MinWidth="200"
                                  VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <TextBlock x:Name="JournalDateLabel" Grid.Column="2" Text="Date:" VerticalAlignment="Center"
                                   Margin="0,0,8,0" Foreground="{DynamicResource PrimaryForeground}"/>
                        <DatePicker x:Name="JournalDatePicker" Grid.Column="3" VerticalAlignment="Center"
                                    Margin="0,0,12,0"/>
                        <Button x:Name="JournalLoadBtn" Grid.Column="4" Content="Load" Padding="14,8"
                                Background="#17A2B8" Foreground="White" BorderThickness="0" Cursor="Hand"
                                Click="JournalLoadBtn_Click" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </Grid>
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                            Background="{DynamicResource PanelBackground}" Padding="12">
                        <StackPanel>
                            <TextBlock x:Name="JournalEntryStatusText" Text="" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <RichTextBox x:Name="JournalReadOnlyRichTextBox" IsReadOnly="True" IsDocumentEnabled="True"
                                         BorderThickness="0" Background="Transparent"
                                         VerticalScrollBarVisibility="Auto" MinHeight="160" MaxHeight="360"
                                         Foreground="{DynamicResource PrimaryForeground}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ========== REPORT CONFIGURATION SECTION HEADER ========== -->
            <TextBlock Grid.Row="5" x:Name="ReportConfigTitle" Text="Report Configuration" FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryForeground}" Margin="0,4,0,16"/>

            <!-- ========== REPORT CONFIGURATION CARDS GRID ========== -->
            <Grid Grid.Row="6" Margin="0,0,0,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- CARD A: TIME PERIOD & DATE RANGE -->
                <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource ContentBackground}" Padding="20"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="📅 Time Period &amp; Date Range" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock x:Name="PeriodLabel" Grid.Row="0" Grid.Column="0" Text="Period:" VerticalAlignment="Center" 
                                       Margin="0,0,12,0" Foreground="{DynamicResource PrimaryForeground}"/>
                            <ComboBox x:Name="PeriodCombo" Grid.Row="0" Grid.Column="1" SelectionChanged="PeriodCombo_SelectionChanged"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Date Range:" VerticalAlignment="Center" 
                                       Margin="0,0,12,0" Foreground="{DynamicResource PrimaryForeground}"/>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <DatePicker x:Name="DateFromPicker" Width="120" Margin="0,0,8,0" SelectedDateChanged="DateRange_Changed"/>
                                <TextBlock Text="to" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource SecondaryForeground}"/>
                                <DatePicker x:Name="DateToPicker" Width="120" SelectedDateChanged="DateRange_Changed"/>
                            </StackPanel>
                            
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Format:" VerticalAlignment="Center" 
                                       Margin="0,0,12,0" Foreground="{DynamicResource PrimaryForeground}"/>
                            <ComboBox x:Name="FormatCombo" Grid.Row="4" Grid.Column="1"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- CARD B: FILTERS -->
                <Border Grid.Row="0" Grid.Column="2" Background="{DynamicResource ContentBackground}" Padding="20"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="🔍 Filters" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Branch:" Width="80" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="BranchCombo" Grid.Row="0" Grid.Column="1" SelectionChanged="ReportScopeFilter_Changed"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Section:" Width="80" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="SectionCombo" Grid.Row="2" Grid.Column="1" SelectionChanged="ReportScopeFilter_Changed"/>
                            
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Status:" Width="80" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="StatusCombo" Grid.Row="4" Grid.Column="1"/>
                            
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Doc Type:" Width="80" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="DocumentTypeCombo" Grid.Row="6" Grid.Column="1"/>
                            
                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Engagement:" Width="80" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="EngagementCombo" Grid.Row="8" Grid.Column="1"/>
                            
                            <TextBlock Grid.Row="10" Grid.Column="0" Text="User:" Width="80" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="UserCombo" Grid.Row="10" Grid.Column="1"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- CARD C: REPORT TYPE SELECTION -->
                <Border Grid.Row="2" Grid.Column="0" Background="{DynamicResource ContentBackground}" Padding="20"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="📊 Report Type Selection" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,16"/>
                        <Grid x:Name="ReportTypePanel">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <RadioButton x:Name="RbDailySummary" Grid.Row="0" Grid.Column="0" Content="📅 Daily Summary" GroupName="ReportType" IsChecked="True"/>
                            <RadioButton x:Name="RbBranchSummary" Grid.Row="0" Grid.Column="2" Content="🏢 Branch Summary" GroupName="ReportType"/>
                            <RadioButton x:Name="RbSectionSummary" Grid.Row="0" Grid.Column="4" Content="📑 Section Summary" GroupName="ReportType"/>
                            
                            <RadioButton x:Name="RbStatusSummary" Grid.Row="2" Grid.Column="0" Content="📊 Status Summary" GroupName="ReportType"/>
                            <RadioButton x:Name="RbDocumentType" Grid.Row="2" Grid.Column="2" Content="📄 Document Type" GroupName="ReportType"/>
                            <RadioButton x:Name="RbPerformance" Grid.Row="2" Grid.Column="4" Content="📈 Performance" GroupName="ReportType"/>
                            
                            <RadioButton x:Name="RbIssuesFocus" Grid.Row="4" Grid.Column="0" Content="⚠ Issues &amp; Focus" GroupName="ReportType"/>
                            <RadioButton x:Name="RbUserActivity" Grid.Row="4" Grid.Column="2" Content="👤 User Activity" GroupName="ReportType"/>
                            <RadioButton x:Name="RbAssignmentSummary" Grid.Row="4" Grid.Column="4" Content="✓ Assignment Summary" GroupName="ReportType"/>
                            
                            <RadioButton x:Name="RbAuditTrail" Grid.Row="6" Grid.Column="0" Content="📜 Audit Trail" GroupName="ReportType"/>
                            <RadioButton x:Name="RbExecutiveSummary" Grid.Row="6" Grid.Column="2" Content="📋 Executive Summary" GroupName="ReportType"/>
                            <RadioButton x:Name="RbExecutiveDashboard" Grid.Row="6" Grid.Column="4" Content="🏠 Executive Dashboard" GroupName="ReportType"
                                         Checked="RbExecutiveDashboard_Checked" Unchecked="RbExecutiveDashboard_Unchecked"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- CARD D: ADVANCED OPTIONS -->
                <Border Grid.Row="2" Grid.Column="2" Background="{DynamicResource ContentBackground}" Padding="20"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="⚙️ Advanced Options" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,16"/>
                        
                        <CheckBox x:Name="IncludeChartsCheck" Content="Include charts (where applicable)" IsChecked="True" Margin="0,0,0,12"/>
                        <CheckBox x:Name="IncludeTocCheck" Content="Table of contents (Executive Summary)" IsChecked="True" Margin="0,0,0,8"/>
                        <CheckBox x:Name="IncludeBrandingCheck" Content="Branding &amp; cover logo (Executive Summary)" IsChecked="True" Margin="0,0,0,8"/>
                        <CheckBox x:Name="IncludeDisclaimerCheck" Content="Regulatory disclaimer (Executive Summary)" IsChecked="True" Margin="0,0,0,12"/>
                        
                        <CheckBox x:Name="ExportPerBranchCheck" Content="Export per branch/section (multiple PDFs)" Margin="0,0,0,8"/>
                        <CheckBox x:Name="ZipPerBranchCheck" Content="ZIP output" IsEnabled="{Binding IsChecked, ElementName=ExportPerBranchCheck}" 
                                  Margin="20,0,0,16"/>
                        
                        <!-- Report Language -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="Report Language:" VerticalAlignment="Center" Margin="0,0,12,0" 
                                       Foreground="{DynamicResource PrimaryForeground}"/>
                            <ComboBox x:Name="ReportLanguageCombo" Width="180" SelectedIndex="0">
                                <ComboBoxItem Content="English" Tag="en"/>
                                <ComboBoxItem Content="العربية (Arabic)" Tag="ar"/>
                            </ComboBox>
                        </StackPanel>
                        
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Template:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <ComboBox x:Name="TemplateCombo" Grid.Row="0" Grid.Column="1" DisplayMemberPath="Name"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Watermark:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <ComboBox x:Name="WatermarkCombo" Grid.Row="2" Grid.Column="1"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ========== EXPORT ACTIONS BAR ========== -->
            <Border Grid.Row="7" Background="{DynamicResource ContentBackground}" Padding="20" Margin="0,0,0,16"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="Export &amp; Actions" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Export Buttons Row -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Button x:Name="GeneratePdfBtn" Content="📄 Generate PDF" Padding="20,12" Background="#0078D4" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" Click="GeneratePdfBtn_Click" FontWeight="SemiBold" FontSize="14"/>
                            <Button x:Name="GenerateExcelBtn" Content="📊 Export Excel" Padding="20,12" Margin="12,0,0,0"
                                    Background="#28A745" Foreground="White" BorderThickness="0" Cursor="Hand" Click="GenerateExcelBtn_Click" 
                                    FontWeight="SemiBold" FontSize="14"/>
                            <Button x:Name="GenerateCsvBtn" Content="📋 Export CSV" Padding="20,12" Margin="12,0,0,0"
                                    Background="#6C757D" Foreground="White" BorderThickness="0" Cursor="Hand" Click="GenerateCsvBtn_Click" 
                                    FontWeight="SemiBold" FontSize="14"/>
                            <Button x:Name="CreateDraftBtn" Content="📝 Create Draft" Padding="20,12" Margin="12,0,0,0"
                                    Background="#9C27B0" Foreground="White" BorderThickness="0" Cursor="Hand" Click="CreateDraftBtn_Click"
                                    FontWeight="SemiBold" FontSize="14"
                                    ToolTip="Create an editable draft before final export"/>
                            <Button x:Name="CancelGenerationBtn" Content="❌ Cancel" Padding="20,12" Margin="12,0,0,0"
                                    Background="#DC3545" Foreground="White" BorderThickness="0" Cursor="Hand" Click="CancelGeneration_Click"
                                    FontWeight="SemiBold" FontSize="14" IsEnabled="False"
                                    ToolTip="Cancel current report generation"/>
                        </StackPanel>
                        
                        <!-- Saved Configs Row -->
                        <StackPanel x:Name="SavedConfigsRow" Grid.Row="2" Orientation="Horizontal">
                            <TextBlock Text="Saved Configs:" VerticalAlignment="Center" Margin="0,0,12,0" 
                                       Foreground="{DynamicResource SecondaryForeground}"/>
                            <ComboBox x:Name="SavedConfigCombo" Width="220" DisplayMemberPath="DisplayName"
                                      SelectionChanged="SavedConfigCombo_SelectionChanged"/>
                            <Button x:Name="FavoriteConfigBtn" Content="★" Padding="10,8" Margin="8,0,0,0"
                                    ToolTip="Toggle favorite for selected config" FontSize="14" Click="FavoriteConfigBtn_Click"
                                    Background="{DynamicResource ButtonSecondaryBackground}" Foreground="#FFC107" BorderThickness="0" Cursor="Hand"/>
                            <Button x:Name="SaveConfigBtn" Content="💾 Save Config" Padding="12,8" Margin="8,0,0,0"
                                    Background="#17A2B8" Foreground="White" BorderThickness="0" Cursor="Hand" Click="SaveConfigBtn_Click"/>
                            <Button x:Name="ManageConfigsBtn" Content="⚙️ Manage..." Padding="12,8" Margin="8,0,0,0"
                                    Background="#6C757D" Foreground="White" BorderThickness="0" Cursor="Hand" Click="ManageConfigsBtn_Click"/>
                            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="16,0,0,0" 
                                       Foreground="{DynamicResource SecondaryForeground}" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                    <ProgressBar x:Name="ProgressBar" Height="4" Margin="0,12,0,0" Visibility="Collapsed" IsIndeterminate="True"/>
                </StackPanel>
            </Border>

            <!-- ========== RECENT REPORTS SECTION ========== -->
            <Border Grid.Row="8" Background="{DynamicResource ContentBackground}" Padding="20" Margin="0,0,0,16"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="📄 Recent Reports" FontSize="15" FontWeight="SemiBold" 
                                   Foreground="{DynamicResource PrimaryForeground}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,8,0" 
                                       Foreground="{DynamicResource SecondaryForeground}" FontSize="12"/>
                            <TextBox x:Name="ReportHistoryFilter" Width="180" Padding="6,4"
                                     TextChanged="ReportHistoryFilter_TextChanged"/>
                        </StackPanel>
                    </Grid>
                    <ListBox x:Name="ReportHistoryList" Height="100" SelectionChanged="ReportHistoryList_SelectionChanged"
                             BorderThickness="0" Background="Transparent" MouseDoubleClick="ReportHistoryList_MouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8" Margin="0,0,0,4" Background="{DynamicResource PanelBackground}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3"
                                        Cursor="Hand">
                                    <TextBlock Text="{Binding DisplayText}" FontSize="12" 
                                               Foreground="{DynamicResource PrimaryForeground}"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- ========== EXECUTIVE DASHBOARD (shown when Executive Dashboard selected) ========== -->
            <Border x:Name="DashboardPanel" Grid.Row="9" Visibility="Collapsed" Margin="0,0,0,16">
                <views:ExecutiveDashboardView x:Name="ExecutiveDashboardControl"/>
            </Border>

            <!-- ========== ATTESTATION PANEL ========== -->
            <Border x:Name="AttestationPanel" Grid.Row="10" Background="{DynamicResource ContentBackground}" Padding="20" Margin="0,0,0,16"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="📋 Report Attestation" FontSize="15" FontWeight="SemiBold" 
                               Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,12"/>
                    <TextBlock x:Name="AttestationStatusText" Text="" FontSize="12" 
                               Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,12" TextWrapping="Wrap"/>
                    <StackPanel x:Name="AttestationButtonsPanel" Orientation="Horizontal" Visibility="Collapsed">
                        <Button x:Name="ReviewBtn" Content="✓ Mark Reviewed" Padding="14,10" Margin="0,0,8,0" 
                                Background="#17A2B8" Foreground="White" BorderThickness="0" Click="ReviewBtn_Click" FontWeight="SemiBold"/>
                        <Button x:Name="ApproveBtn" Content="✓ Approve" Padding="14,10" Background="#28A745" 
                                Foreground="White" BorderThickness="0" Click="ApproveBtn_Click" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ========== STATUS / MESSAGE AREA ========== -->
