<UserControl x:Class="WorkAudit.Views.WorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:ctrl="clr-namespace:WorkAudit.Controls"
             xmlns:pdfViewer="clr-namespace:PdfiumViewer;assembly=PdfiumViewer">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/LayoutConstants.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        <Style x:Key="PanelHeader" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style x:Key="PanelHeaderConnected" TargetType="Border" BasedOn="{StaticResource PanelHeader}">
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style x:Key="PanelTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource DimForeground}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="PanelContent" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ContentBackground}"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
        <Style x:Key="ToggleBtn" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="2">
                            <ContentPresenter Content="{TemplateBinding Content}" 
                                            ContentTemplate="{TemplateBinding ContentTemplate}"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource HoverBackground}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource HoverBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="InspectorExpanderStyle" TargetType="Expander">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="InspectorSectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource DimForeground}"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="InspectorFlatSection" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ContentBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{StaticResource MediumCornerRadius}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="InspectorCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{StaticResource MediumCornerRadius}"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
        <Style x:Key="WorkspaceToolButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonSecondaryBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Background="{DynamicResource ContentBackground}" Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Persistent toolbar - toggles always visible -->
        <Border Grid.Row="0" Background="{DynamicResource PanelBackground}" Padding="12,8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Workspace" Foreground="{DynamicResource DimForeground}" FontSize="12" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <ToggleButton x:Name="InspectorToggle" Style="{StaticResource ToggleBtn}" Content="Filters &amp; Details" IsChecked="True"
                              ToolTip="Toggle Filters and Details panel" Margin="0,0,8,0"
                              Checked="InspectorToggle_Changed" Unchecked="InspectorToggle_Changed"/>
                <ToggleButton x:Name="BrowserToggle" Style="{StaticResource ToggleBtn}" Content="Browser" IsChecked="False"
                              ToolTip="Toggle Browser panel" Margin="8,0,0,0"
                              Checked="BrowserToggle_Changed" Unchecked="BrowserToggle_Changed"/>
                <ToggleButton x:Name="PreviewToggle" Style="{StaticResource ToggleBtn}" Content="Document Preview" IsChecked="True"
                              ToolTip="Toggle Document Preview panel" Margin="8,0,0,0"
                              Checked="PreviewToggle_Changed" Unchecked="PreviewToggle_Changed"/>
                <ToggleButton x:Name="DetailsOcrToolbarToggle" Style="{StaticResource ToggleBtn}" Content="Details &amp; OCR" IsChecked="False"
                              ToolTip="Show or hide selected document details and OCR" Margin="8,0,0,0"
                              Checked="DetailsOcrToggle_Changed" Unchecked="DetailsOcrToggle_Changed"/>
            </StackPanel>
        </Border>
        <!-- Follow-up reminder banner - visible when documents are due or overdue -->
        <Border Grid.Row="1" x:Name="FollowUpReminderPanel" Background="#FFF3CD" BorderBrush="#FFC107" BorderThickness="0,0,0,1"
                Padding="12,8" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Vertical">
                    <TextBlock x:Name="FollowUpReminderTitle" Text="Documents need follow-up" Foreground="#856404" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ItemsControl x:Name="FollowUpReminderList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding DocumentListDisplay}" Padding="4,2" Margin="0,0,0,2"
                                        Background="Transparent" Foreground="#856404" BorderThickness="0" Cursor="Hand"
                                        HorizontalContentAlignment="Left" Click="FollowUpReminderItem_Click"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                <Button Grid.Column="1" x:Name="FollowUpReminderDismissBtn" Content="Dismiss" Padding="8,4" VerticalAlignment="Top"
                        Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource DimForeground}" BorderThickness="0" Cursor="Hand" Click="FollowUpReminderDismiss_Click"/>
            </Grid>
        </Border>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="InspectorCol" Width="400" MinWidth="0" MaxWidth="900"/>
                <ColumnDefinition x:Name="InspectorSplitterCol" Width="4" MinWidth="0" MaxWidth="4"/>
                <ColumnDefinition x:Name="PreviewCol" Width="*" MinWidth="0"/>
                <ColumnDefinition x:Name="PreviewSplitterCol" Width="4"/>
                <ColumnDefinition x:Name="BrowserCol" Width="*" MinWidth="0"/>
            </Grid.ColumnDefinitions>

        <!-- Left: Inspector (sticky search, scrollable details/actions, file tree + documents) -->
        <Border Grid.Column="0" x:Name="InspectorPanel" Background="{DynamicResource ContentBackground}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Style="{StaticResource PanelHeader}">
                    <TextBlock Text="Filters &amp; Details" Style="{StaticResource PanelTitle}" VerticalAlignment="Center"/>
                </Border>
                <Grid Grid.Row="1" x:Name="InspectorBodyGrid">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*" MinHeight="80"/>
                            </Grid.RowDefinitions>
                            <!-- Sticky search / filters -->
                            <Border Grid.Row="0" Padding="12,10" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                                    PreviewKeyDown="InspectorFilterArea_PreviewKeyDown">
                                <StackPanel KeyboardNavigation.TabNavigation="Local">
                                    <TextBlock Text="Search" Style="{StaticResource InspectorSectionTitle}" Margin="0,0,0,4"/>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" MinWidth="76"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Branch" VerticalAlignment="Center" Margin="0,0,8,0"
                                                   FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource SecondaryForeground}"/>
                                        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="FilterBranch" Margin="0,0,0,6" MinHeight="28"
                                                  SelectionChanged="FilterBranch_SelectionChanged"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Section" VerticalAlignment="Center" Margin="0,0,8,0"
                                                   FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource SecondaryForeground}"/>
                                        <ComboBox Grid.Row="1" Grid.Column="1" x:Name="FilterSection" Margin="0,0,0,6" MinHeight="28"
                                                  SelectionChanged="FilterSection_SelectionChanged"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Type" VerticalAlignment="Center" Margin="0,0,8,0"
                                                   FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource SecondaryForeground}"/>
                                        <ComboBox Grid.Row="2" Grid.Column="1" x:Name="FilterDocType" Margin="0,0,0,6" MinHeight="28"
                                                  SelectionChanged="FilterDocType_SelectionChanged"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="From" VerticalAlignment="Center" Margin="0,0,8,0"
                                                   FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource SecondaryForeground}"/>
                                        <DatePicker Grid.Row="3" Grid.Column="1" x:Name="FilterDateFrom" Margin="0,0,0,6" MinHeight="28"
                                                    SelectedDateChanged="FilterDate_Changed"/>
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="To" VerticalAlignment="Center" Margin="0,0,8,0"
                                                   FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource SecondaryForeground}"/>
                                        <DatePicker Grid.Row="4" Grid.Column="1" x:Name="FilterDateTo" Margin="0,0,0,2" MinHeight="28"
                                                    SelectedDateChanged="FilterDate_Changed"/>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <Button x:Name="FilterSearchBtn" Content="Search" Padding="12,6" Margin="0,0,8,0" Click="FilterSearchBtn_Click"
                                                Background="{DynamicResource AccentPrimaryBrush}" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                        <Button x:Name="FilterClearBtn" Content="Clear" Padding="12,6" Click="FilterClearBtn_Click"
                                                Style="{StaticResource WorkspaceToolButton}"/>
                                    </StackPanel>
                                    <TextBlock x:Name="FilterSummaryText" TextWrapping="Wrap" FontSize="{StaticResource FontSizeSmall}"
                                               Foreground="{DynamicResource DimForeground}" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                            <Grid Grid.Row="1" x:Name="FileTreeDocumentsGrid" MinHeight="60" Background="{DynamicResource AlternateRowBackground}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" MinHeight="48"/>
                                    <RowDefinition Height="4"/>
                                    <RowDefinition Height="*" MinHeight="48"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Padding="12,8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,6">
                                            <TextBlock DockPanel.Dock="Left" Text="File browser" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SecondaryForeground}" FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold"/>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                <Button x:Name="FileTreeRefreshBtn" Content="Refresh" Style="{StaticResource WorkspaceToolButton}" Margin="4,0,0,0"
                                                        Click="FileTreeRefreshBtn_Click" ToolTip="Reload folder tree"/>
                                                <Button x:Name="FileTreeExpandAllBtn" Content="Expand all" Style="{StaticResource WorkspaceToolButton}" Margin="4,0,0,0"
                                                        Click="FileTreeExpandAllBtn_Click" ToolTip="Expand all folders"/>
                                                <Button x:Name="FileTreeCollapseAllBtn" Content="Collapse all" Style="{StaticResource WorkspaceToolButton}" Margin="4,0,0,0"
                                                        Click="FileTreeCollapseAllBtn_Click" ToolTip="Collapse all folders"/>
                                            </StackPanel>
                                        </DockPanel>
                                        <TreeView Grid.Row="1" x:Name="FileTree" Background="Transparent" BorderThickness="0"
                                                  FontSize="{StaticResource FontSizeNormal}" Padding="0,4,0,0"
                                                  SelectedItemChanged="FileTree_SelectedItemChanged"/>
                                    </Grid>
                                </Border>
                                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                              x:Name="FileTreeDocumentsSplitter"
                                              Background="{DynamicResource BorderBrush}" ResizeDirection="Rows" Cursor="SizeNS"
                                              DragCompleted="FileTreeDocumentsSplitter_DragCompleted"/>
                                <Border Grid.Row="2" Padding="12,8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="Documents" Foreground="{DynamicResource SecondaryForeground}"
                                                   FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold" VerticalAlignment="Center"
                                                   ToolTip="Ctrl+Click or Shift+Click to select multiple items"/>
                                        <Border Grid.Row="1" x:Name="AssignmentFilterPanel" Visibility="Collapsed" Background="{DynamicResource ContentBackground}" Padding="8,6" Margin="0,6,0,8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource MediumCornerRadius}">
                                            <StackPanel>
                                                <TextBlock x:Name="AssignmentFilterLabel" Text="Filter" FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,4"/>
                                                <WrapPanel>
                                                    <RadioButton x:Name="RbAssignmentPending" Content="Pending" GroupName="AssignmentStatusFilter" Margin="0,0,16,4" IsChecked="True" Checked="AssignmentFilter_Changed"/>
                                                    <RadioButton x:Name="RbAssignmentInProgress" Content="In Progress" GroupName="AssignmentStatusFilter" Margin="0,0,16,4" Checked="AssignmentFilter_Changed"/>
                                                    <RadioButton x:Name="RbAssignmentCompleted" Content="Completed" GroupName="AssignmentStatusFilter" Margin="0,0,16,4" Checked="AssignmentFilter_Changed"/>
                                                    <RadioButton x:Name="RbAssignmentAll" Content="All" GroupName="AssignmentStatusFilter" Margin="0,0,16,4" Checked="AssignmentFilter_Changed"/>
                                                    <CheckBox x:Name="AssignmentOverdueOnlyCheck" Content="Show overdue only" Margin="0,0,0,4" Checked="AssignmentFilter_Changed" Unchecked="AssignmentFilter_Changed"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                        <TextBox Grid.Row="2" x:Name="DocumentListFilterBox" Margin="0,0,0,8" Padding="8,6" MinHeight="28"
                                                 Background="{DynamicResource ContentBackground}" Foreground="{DynamicResource PrimaryForeground}"
                                                 BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                 FontSize="{StaticResource FontSizeSmall}"
                                                 ToolTip="Filter documents by displayed name"
                                                 TextChanged="DocumentListFilterBox_TextChanged"
                                                 AutomationProperties.Name="Filter documents"/>
                                        <ListBox Grid.Row="3" x:Name="DocumentList" Background="Transparent" BorderThickness="0"
                                                 FontSize="{StaticResource FontSizeSmall}" Padding="4,2"
                                                 SelectionMode="Extended"
                                                 SelectionChanged="DocumentList_SelectionChanged"
                                                 ContextMenuOpening="DocumentList_ContextMenuOpening"
                                                 MouseRightButtonDown="DocumentList_MouseRightButtonDown"
                                                 VirtualizingPanel.IsVirtualizing="True"
                                                 VirtualizingPanel.VirtualizationMode="Recycling">
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <VirtualizingStackPanel/>
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DocumentListDisplay}" TextTrimming="CharacterEllipsis"/>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                            <ListBox.ContextMenu>
                                                <ContextMenu x:Name="DocumentContextMenu">
                                                    <MenuItem Header="Open" Click="ContextOpen_Click"/>
                                                    <MenuItem Header="Open in Explorer" Click="ContextOpenInExplorer_Click"/>
                                                    <MenuItem Header="Copy Path" Click="ContextCopyPath_Click"/>
                                                    <Separator/>
                                                    <MenuItem Header="Set Status" x:Name="ContextSetStatusItem">
                                                        <MenuItem Header="Draft" Click="SetStatusOption_Click" Tag="Draft"/>
                                                        <MenuItem Header="Reviewed" Click="SetStatusOption_Click" Tag="Reviewed"/>
                                                        <MenuItem Header="Ready for Audit" Click="SetStatusOption_Click" Tag="Ready for Audit"/>
                                                        <MenuItem Header="Issue" Click="SetStatusOption_Click" Tag="Issue"/>
                                                        <MenuItem Header="Cleared" Click="SetStatusOption_Click" Tag="Cleared"/>
                                                    </MenuItem>
                                                    <MenuItem x:Name="ContextAssignItem" Header="Assign..." Click="ContextAssign_Click"/>
                                                    <MenuItem x:Name="ContextFlagFollowUpItem" Header="Flag for Follow-up" Click="ContextFlagFollowUp_Click"/>
                                                    <MenuItem Header="Correct Classification..." Click="ContextCorrectClassification_Click"/>
                                                    <Separator/>
                                                    <MenuItem Header="View Details" Click="ContextViewDetails_Click"/>
                                                </ContextMenu>
                                            </ListBox.ContextMenu>
                                        </ListBox>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
            </Grid>
        </Border>
        <GridSplitter Grid.Column="1" x:Name="InspectorBrowserSplitter" Width="4" HorizontalAlignment="Stretch"
                      Background="{DynamicResource BorderBrush}" ResizeDirection="Columns" Cursor="SizeWE"
                      DragCompleted="InspectorBrowserSplitter_DragCompleted"/>

        <!-- Right: Browser panel -->
        <Border Grid.Column="4" x:Name="BrowserPanel" Background="{DynamicResource ContentBackground}">
            <DockPanel>
                <Border DockPanel.Dock="Top" Style="{StaticResource PanelHeader}">
                    <TextBlock Text="Browser" Style="{StaticResource PanelTitle}" VerticalAlignment="Center"/>
                </Border>
                <!-- Quick links: scrollable chips + Add link -->
                <Border DockPanel.Dock="Top" Padding="8,6" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" VerticalContentAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <ItemsControl x:Name="QuickLinksChips">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Title}" Padding="10,5" Margin="0,0,6,0" Cursor="Hand"
                                                Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}"
                                                BorderThickness="0" BorderBrush="{DynamicResource BorderBrush}"
                                                Click="QuickLinkChip_Click" ToolTip="{Binding Url}"
                                                Tag="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="ChipBorder" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}"
                                                                        BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                                                        CornerRadius="12" Cursor="{TemplateBinding Cursor}">
                                                                    <ContentPresenter Content="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="ChipBorder" Property="Background" Value="{DynamicResource HoverBackground}"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                            <Button.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Remove" Click="QuickLinkRemove_Click"/>
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button x:Name="AddQuickLinkBtn" Content="+ Add link" Padding="10,5" Cursor="Hand"
                                    Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource DimForeground}"
                                    BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                                    Click="AddQuickLink_Click" ToolTip="Add a quick link"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
                <Border DockPanel.Dock="Top" Padding="8,6" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="UrlBox" Padding="8,6" VerticalContentAlignment="Center" KeyDown="UrlBox_KeyDown"
                                 Background="{DynamicResource ContentBackground}" Foreground="{DynamicResource DimForeground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                 FontSize="13" CaretBrush="{DynamicResource PrimaryForeground}"/>
                        <Button Grid.Column="1" Content="Go" Margin="8,0,0,0" Padding="16,6" Click="Go_Click"
                                Background="{DynamicResource AccentPrimaryBrush}" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    </Grid>
                </Border>
                <Border Style="{StaticResource PanelContent}" Margin="0" Background="{DynamicResource ContentBackground}">
                    <wv2:WebView2 x:Name="WebBrowser"/>
                </Border>
            </DockPanel>
        </Border>
        <GridSplitter Grid.Column="3" x:Name="BrowserSplitter" Width="4" HorizontalAlignment="Stretch"
                      Background="{DynamicResource BorderBrush}" ResizeDirection="Columns" Cursor="SizeWE"/>

        <!-- Center: Document Preview panel (image or PDF previewer) -->
        <Border Grid.Column="2" x:Name="PreviewPanel" Background="{DynamicResource ContentBackground}">
            <Grid>
                <DockPanel LastChildFill="True">
                <Border DockPanel.Dock="Top" Style="{StaticResource PanelHeaderConnected}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Document Preview" Style="{StaticResource PanelTitle}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <ToggleButton x:Name="PreviewTextOnImageToggle" Style="{StaticResource ToggleBtn}" Content="Text on image" IsChecked="False"
                                          IsEnabled="False" Margin="0,0,8,0"
                                          ToolTip="Scan text with Tesseract (same language as Control Panel → OCR). For PDFs, only the current page is shown as an image while this is on; turn off to browse all pages again. Drag to select, then copy. Images: 0° rotation only."
                                          Checked="PreviewTextOnImageToggle_Checked" Unchecked="PreviewTextOnImageToggle_Unchecked"/>
                            <ToggleButton x:Name="DetailsOcrFlyoutToggle" Style="{StaticResource ToggleBtn}" Content="Details &amp; OCR" IsChecked="False"
                                          ToolTip="Show or hide selected document details and OCR"
                                          Checked="DetailsOcrToggle_Changed" Unchecked="DetailsOcrToggle_Changed"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <ctrl:PdfPreviewToolsPanel x:Name="WorkspacePdfPreviewTools" DockPanel.Dock="Top" Visibility="Collapsed"/>
                <Border x:Name="PdfTextOnImageInfoBar" DockPanel.Dock="Top" Visibility="Collapsed" Padding="10,6"
                        Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <TextBlock x:Name="PdfTextOnImageInfoText" TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource DimForeground}"/>
                </Border>
                <!-- Markup & workflow: vertical strip beside preview (more room for document) -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="0"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="WorkspaceMarkupToolBar" Grid.Column="0" Visibility="Collapsed"
                            HorizontalAlignment="Left"
                            Width="68"
                            Margin="0" Padding="3,4"
                            Background="{DynamicResource ContentBackground}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0"
                            VerticalAlignment="Stretch">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Center"
                                      Focusable="False">
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="56">
                                <TextBlock TextAlignment="Center"
                                           Text="Markup &amp;&#x0a;workflow"
                                           Foreground="{DynamicResource DimForeground}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           TextWrapping="NoWrap"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="Markup" TextAlignment="Center" Style="{StaticResource InspectorSectionTitle}" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="32">
                                    <RadioButton x:Name="MarkupBrowseBtn" GroupName="WsMarkupTools" Content="⇅" Width="32" Height="28" Margin="0,0,0,3"
                                                 IsChecked="True" Checked="MarkupBrowse_Checked"
                                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                                 HorizontalAlignment="Left"
                                                 Foreground="{DynamicResource PrimaryForeground}" ToolTip="Scroll &amp; view (scrollbars, wheel; Ctrl+wheel zoom on PDF)"/>
                                    <RadioButton x:Name="MarkupPanBtn" GroupName="WsMarkupTools" Content="✋" Width="32" Height="28" Margin="0,0,0,3"
                                                 Checked="MarkupPan_Checked"
                                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                                 HorizontalAlignment="Left"
                                                 Foreground="{DynamicResource PrimaryForeground}" ToolTip="Pan"/>
                                    <RadioButton x:Name="MarkupHighlightBtn" GroupName="WsMarkupTools" Content="🖍" Width="32" Height="28" Margin="0,0,0,3"
                                                 Checked="MarkupHighlight_Checked"
                                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                                 HorizontalAlignment="Left"
                                                 Foreground="{DynamicResource PrimaryForeground}" ToolTip="Highlight"/>
                                    <RadioButton x:Name="MarkupRectBtn" GroupName="WsMarkupTools" Content="▭" Width="32" Height="28" Margin="0,0,0,3"
                                                 Checked="MarkupRect_Checked"
                                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                                 HorizontalAlignment="Left"
                                                 Foreground="{DynamicResource PrimaryForeground}" ToolTip="Rectangle"/>
                                    <RadioButton x:Name="MarkupEraseBtn" GroupName="WsMarkupTools" Content="⌫" Width="32" Height="28" Margin="0,0,0,3"
                                                 Checked="MarkupErase_Checked"
                                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                                 HorizontalAlignment="Left"
                                                 Foreground="{DynamicResource PrimaryForeground}" ToolTip="Erase"/>
                                    <RadioButton x:Name="MarkupMarkupBtn" GroupName="WsMarkupTools" Content="✎" Width="32" Height="28" Margin="0,0,0,3"
                                                 Checked="MarkupMarkup_Checked"
                                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                                 HorizontalAlignment="Left"
                                                 Foreground="{DynamicResource PrimaryForeground}" ToolTip="Markup pen"/>
                                    <RadioButton x:Name="MarkupTextBtn" GroupName="WsMarkupTools" Content="T" Width="32" Height="28" Margin="0,0,0,3"
                                                 Checked="MarkupText_Checked"
                                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                                 HorizontalAlignment="Left"
                                                 Foreground="{DynamicResource PrimaryForeground}" ToolTip="Text annotation"/>
                                    <Button x:Name="MarkupSaveBtn" Content="💾" Width="32" Height="28" Margin="0,0,0,3" Click="MarkupSaveBtn_Click"
                                            VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                            HorizontalAlignment="Left"
                                            Background="{DynamicResource AccentPrimaryBrush}" Foreground="White" BorderThickness="0" Cursor="Hand"
                                            ToolTip="Save markup"/>
                                    <Button x:Name="MarkupNoteBtn" Content="📝" Width="32" Height="28" Margin="0,0,0,0" Click="MarkupNoteBtn_Click"
                                            VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                            HorizontalAlignment="Left"
                                            Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand"
                                            ToolTip="Add note"/>
                                </StackPanel>
                                <TextBlock Text="Workflow" TextAlignment="Center" Style="{StaticResource InspectorSectionTitle}" Margin="0,8,0,4"/>
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="32">
                                    <Button x:Name="SetStatusBtn" Content="⚑" Width="32" Height="28" Margin="0,0,0,3"
                                            IsEnabled="False" Click="SetStatusBtn_Click"
                                            HorizontalAlignment="Left"
                                            Style="{StaticResource WorkspaceToolButton}"
                                            ToolTip="Change document status">
                                        <Button.ContextMenu>
                                            <ContextMenu x:Name="SetStatusContextMenu" Placement="Bottom">
                                                <MenuItem Header="Draft" Click="SetStatusOption_Click" Tag="Draft"/>
                                                <MenuItem Header="Reviewed" Click="SetStatusOption_Click" Tag="Reviewed"/>
                                                <MenuItem Header="Ready for Audit" Click="SetStatusOption_Click" Tag="Ready for Audit"/>
                                                <MenuItem Header="Issue" Click="SetStatusOption_Click" Tag="Issue"/>
                                                <MenuItem Header="Cleared" Click="SetStatusOption_Click" Tag="Cleared"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                    <Button x:Name="FlagFollowUpBtn" Content="🔔" Width="32" Height="28" Margin="0,0,0,3"
                                            IsEnabled="False" Click="FlagFollowUpBtn_Click"
                                            HorizontalAlignment="Left"
                                            Style="{StaticResource WorkspaceToolButton}"
                                            ToolTip="Flag for follow-up"/>
                                    <Button x:Name="AddNoteBtn" Content="＋" Width="32" Height="28" Margin="0,0,0,3"
                                            IsEnabled="False" Click="AddNoteBtn_Click"
                                            HorizontalAlignment="Left"
                                            Background="{DynamicResource AccentSuccessBrush}" Foreground="White" BorderThickness="0" Cursor="Hand"
                                            ToolTip="Quick add note"/>
                                    <Button x:Name="ViewNotesBtn" Content="☰" Width="32" Height="28" Margin="0,0,0,3"
                                            IsEnabled="False" Click="ViewNotesBtn_Click"
                                            HorizontalAlignment="Left"
                                            Style="{StaticResource WorkspaceToolButton}"
                                            ToolTip="View all notes"/>
                                    <Button x:Name="CorrectClassificationBtn" Content="⇄" Width="32" Height="28" Margin="0,0,0,3"
                                            IsEnabled="False" Click="CorrectClassificationBtn_Click"
                                            HorizontalAlignment="Left"
                                            Style="{StaticResource WorkspaceToolButton}"
                                            ToolTip="Correct classification"/>
                                    <Border x:Name="AssignmentGroupBox" Background="Transparent" Margin="0,0,0,3" HorizontalAlignment="Left">
                                        <Button x:Name="AssignBtn" Content="👤" Width="32" Height="28"
                                                IsEnabled="False" Click="AssignBtn_Click"
                                                HorizontalAlignment="Left"
                                                Style="{StaticResource WorkspaceToolButton}"
                                                ToolTip="Assign documents"/>
                                    </Border>
                                    <StackPanel x:Name="AssignmentActionsPanel" Visibility="Collapsed" Orientation="Vertical" Margin="0,0,0,0" HorizontalAlignment="Left">
                                        <Button x:Name="MarkCompleteBtn" Content="✓" Width="32" Height="28" Margin="0,0,0,3"
                                                IsEnabled="False" Click="MarkCompleteBtn_Click"
                                                HorizontalAlignment="Left"
                                                Background="{DynamicResource AccentSuccessBrush}" Foreground="White" BorderThickness="0" Cursor="Hand"
                                                ToolTip="Mark complete"/>
                                        <Button x:Name="ViewDocumentBtn" Content="👁" Width="32" Height="28" Margin="0,0,0,3"
                                                IsEnabled="False" Click="ViewDocumentBtn_Click"
                                                HorizontalAlignment="Left"
                                                Background="{DynamicResource AccentMutedBrush}" Foreground="White" BorderThickness="0" Cursor="Hand"
                                                ToolTip="View document"/>
                                        <Button x:Name="CancelAssignmentBtn" Content="✕" Width="32" Height="28" Margin="0,0,0,0"
                                                IsEnabled="False" Click="CancelAssignmentBtn_Click"
                                                HorizontalAlignment="Left"
                                                Background="{DynamicResource AccentDangerBrush}" Foreground="White" BorderThickness="0" Cursor="Hand"
                                                ToolTip="Cancel assignment"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border x:Name="PdfPageJumpGroup" Margin="0,6,0,0" Padding="2,3" HorizontalAlignment="Center" Visibility="Collapsed"
                                        Background="{DynamicResource PanelBackground}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="{StaticResource SmallCornerRadius}">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="32">
                                        <TextBox x:Name="PdfPageJumpBox" Width="32" Height="26" Margin="0,0,0,3"
                                                 VerticalContentAlignment="Center" Padding="4,2"
                                                 HorizontalAlignment="Left"
                                                 Background="{DynamicResource ContentBackground}" Foreground="{DynamicResource PrimaryForeground}"
                                                 BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" ToolTip="Page number"/>
                                        <Button x:Name="PdfPageGoBtn" Content="→" Width="32" Height="26" Click="PdfPageGoBtn_Click"
                                                HorizontalAlignment="Left"
                                                Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand"
                                                ToolTip="Go to page"/>
                                    </StackPanel>
                                </Border>
                                <!-- Icon only when document has notes; details in ToolTip (see RefreshNotesPreview) -->
                                <TextBlock x:Name="NotesPreviewText" Text="💡" Visibility="Collapsed"
                                           FontSize="15" TextAlignment="Center" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource AccentPrimaryBrush}"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource PanelContent}" Margin="0">
                        <Grid>
                            <ctrl:DocumentViewer x:Name="DocumentPreviewViewer"/>
                            <Grid x:Name="PdfPreviewHost" Visibility="Collapsed" PreviewMouseWheel="PdfPreviewHost_PreviewMouseWheel">
                                <pdfViewer:PDFViewer x:Name="PdfPreviewViewer" FitWidth="False"/>
                                <Canvas x:Name="WorkspacePdfMarkupCanvas" Background="Transparent" IsHitTestVisible="False"
                                        PreviewMouseLeftButtonDown="WorkspacePdfMarkupCanvas_PreviewMouseDown"
                                        PreviewMouseMove="WorkspacePdfMarkupCanvas_PreviewMouseMove"
                                        PreviewMouseLeftButtonUp="WorkspacePdfMarkupCanvas_PreviewMouseUp"
                                        PreviewMouseWheel="WorkspacePdfMarkupCanvas_PreviewMouseWheel"/>
                                <Canvas x:Name="WorkspacePdfOcrCanvas" Background="Transparent" IsHitTestVisible="False" Panel.ZIndex="1" Visibility="Collapsed"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
                </DockPanel>
                <Border x:Name="DetailsOcrFlyoutPanel" HorizontalAlignment="Right" VerticalAlignment="Stretch" Width="380" MaxWidth="480"
                        Panel.ZIndex="2" Visibility="Collapsed" Margin="0"
                        Background="{DynamicResource PanelBackground}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="Selected document" Style="{StaticResource InspectorSectionTitle}" Margin="0,0,0,8"/>
                            <Border Style="{StaticResource InspectorCard}">
                                <TextBlock x:Name="MetadataText" Foreground="{DynamicResource PrimaryForeground}"
                                           FontSize="{StaticResource FontSizeNormal}" TextWrapping="Wrap" LineHeight="20"/>
                            </Border>
                            <Border x:Name="AccountFieldsCard" Style="{StaticResource InspectorCard}" Margin="0,10,0,0">
                                <StackPanel>
                                    <TextBlock Text="Account / transaction" Style="{StaticResource InspectorSectionTitle}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Account or party name" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,2"/>
                                    <TextBox x:Name="AccountNameBox" Padding="6,4" Margin="0,0,0,6" MinHeight="28"
                                             IsEnabled="False" ToolTip="Customer or account holder name"/>
                                    <TextBlock Text="Account number" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,2"/>
                                    <TextBox x:Name="AccountNumberBox" Padding="6,4" Margin="0,0,0,6" MinHeight="28"
                                             IsEnabled="False" ToolTip="Bank or internal account identifier"/>
                                    <TextBlock Text="Transaction reference" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,2"/>
                                    <TextBox x:Name="TransactionReferenceBox" Padding="6,4" Margin="0,0,0,8" MinHeight="28"
                                             IsEnabled="False" ToolTip="Wire ref, cheque no., authorization id, etc."/>
                                    <Button x:Name="SaveAccountFieldsBtn" Content="Save account fields" Padding="8,5" HorizontalAlignment="Left"
                                            IsEnabled="False" Click="SaveAccountFieldsBtn_Click"
                                            Background="{DynamicResource AccentPrimaryBrush}" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="OCR" Style="{StaticResource InspectorSectionTitle}" Margin="0,16,0,8"/>
                            <Border Style="{StaticResource InspectorFlatSection}">
                                <StackPanel>
                                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            Background="{DynamicResource ContentBackground}" Padding="8" Margin="0,0,0,8" MinHeight="60" CornerRadius="{StaticResource SmallCornerRadius}">
                                        <TextBox x:Name="OcrPreviewText" Text="No text extracted yet."
                                                 Foreground="{DynamicResource DimForeground}" FontStyle="Italic"
                                                 FontSize="{StaticResource FontSizeSmall}" TextWrapping="Wrap" MaxHeight="200"
                                                 IsReadOnly="True" BorderThickness="0" Background="Transparent" Padding="0"
                                                 VerticalScrollBarVisibility="Auto"/>
                                    </Border>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="RunOcrBtn" Content="Run OCR" Padding="6,6" Margin="0,0,4,0"
                                                Grid.Column="0" IsEnabled="False" Click="RunOcrBtn_Click"
                                                Background="{DynamicResource AccentPrimaryBrush}" Foreground="White" BorderThickness="0" Cursor="Hand"
                                                ToolTip="Manually trigger OCR extraction"/>
                                        <Button x:Name="ViewOcrBtn" Content="View full" Padding="6,6" Margin="4,0,4,0"
                                                Grid.Column="1" IsEnabled="False" Click="ViewOcrBtn_Click"
                                                Style="{StaticResource WorkspaceToolButton}"
                                                ToolTip="View full OCR extraction results"/>
                                        <Button x:Name="OcrSelectionToNoteBtn" Content="Note from selection" Padding="6,6" Margin="4,0,0,0"
                                                Grid.Column="2" IsEnabled="False" Click="OcrSelectionToNoteBtn_Click"
                                                Style="{StaticResource WorkspaceToolButton}"
                                                ToolTip="Copy selected OCR text into a new note"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
        </Grid>
    </Grid>
</UserControl>
