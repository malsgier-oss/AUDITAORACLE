<UserControl x:Class="WorkAudit.Views.WebcamView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             PreviewKeyDown="WebcamView_PreviewKeyDown"
             PreviewKeyUp="WebcamView_PreviewKeyUp">
    <Grid Background="{DynamicResource PanelBackground}" Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top: Camera + mode controls -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Camera:" Foreground="{DynamicResource PrimaryForeground}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="CameraCombo" Width="180" Margin="0,0,12,0"/>
            <Button x:Name="BtnStart" Content="Start Camera" Padding="12,6" Click="BtnStart_Click"/>
            <Button x:Name="BtnStop" Content="Stop" Padding="12,6" Margin="8,0,0,0"
                    IsEnabled="False" Click="BtnStop_Click"/>
            <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="16,0"/>
            <TextBlock Text="Mode:" Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="11"/>
            <ComboBox x:Name="CaptureModeCombo" Width="90" Margin="0,0,8,0" FontSize="11"
                      ToolTip="Manual = Enter to capture. Auto = stability gate + cooldown."/>
            <CheckBox x:Name="MultiPageCheck" Content="Multi-page" IsChecked="True" Margin="0,0,12,0"
                      VerticalAlignment="Center" FontSize="11" ToolTip="ON = scan multiple pages per document"/>
            <CheckBox x:Name="AutoCropCheck" Content="Auto-crop" IsChecked="True" Margin="0,0,12,0"
                      VerticalAlignment="Center" FontSize="11" ToolTip="Crop to document when detected"/>
        </StackPanel>

        <!-- Primary buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="BtnCapture" Content="Capture (Enter)" Padding="16,10" FontWeight="SemiBold"
                    IsEnabled="False" Click="BtnCapture_Click" Margin="0,0,8,0"/>
            <Button x:Name="BtnFinish" Content="Finish Document (\ key)" Padding="16,10" FontWeight="SemiBold"
                    IsEnabled="False" Click="BtnFinish_Click" Margin="0,0,8,0"/>
            <Button x:Name="BtnRetake" Content="Retake Last (R)" Padding="16,10"
                    IsEnabled="False" Click="BtnRetake_Click" Margin="0,0,8,0"/>
            <Button x:Name="BtnDelete" Content="Delete Selected (Del)" Padding="16,10"
                    IsEnabled="False" Click="BtnDelete_Click"/>
        </StackPanel>

        <!-- Preview + overlay -->
        <Grid Grid.Row="2" MinHeight="200">
            <Border x:Name="PreviewBorder" Background="{DynamicResource ContentBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Image x:Name="PreviewImage" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="Fant"/>
                    <Border x:Name="CaptureFlashOverlay" Background="#6600C853" Visibility="Collapsed" IsHitTestVisible="False"/>
                    <Canvas x:Name="OverlayCanvas" IsHitTestVisible="False"/>
                    <TextBlock x:Name="PlaceholderText" Text="Click Start Camera to begin"
                               Foreground="{DynamicResource SecondaryForeground}" HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="14"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Compact status line -->
        <Grid Grid.Row="3" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="StatusLabel" Text="" Foreground="{DynamicResource SecondaryForeground}" FontSize="11" Margin="0,0,10,0"/>
                <TextBlock x:Name="CameraInfoLabel" Text="" Foreground="{DynamicResource DisabledForeground}" FontSize="11"/>
            </StackPanel>
            <TextBlock Grid.Column="1" Text="Enter:Capture | Finish(\\) | R:Retake | Del:Delete | Space:Tap Capture / Double-tap Finish | Esc:Exit"
                       Foreground="{DynamicResource DisabledForeground}" FontSize="10" Margin="10,0,10,0"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            <TextBlock Grid.Column="2" x:Name="PageCountLabel" Text="Pages: 0" Foreground="{DynamicResource SecondaryForeground}" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center"/>
            <ListBox Grid.Column="3" x:Name="ThumbnailsList" Height="42" MinWidth="160"
                     SelectionMode="Single" SelectionChanged="ThumbnailsList_SelectionChanged"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                     VerticalAlignment="Center">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="2" Padding="4" Background="{DynamicResource ButtonSecondaryBackground}" CornerRadius="4">
                            <TextBlock Text="{Binding DisplayLabel}" FontSize="10" FontWeight="SemiBold"/>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</UserControl>
