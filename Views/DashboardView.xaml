<UserControl x:Class="WorkAudit.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:WorkAudit.Views">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid x:Name="RootGrid" Background="{DynamicResource PanelBackground}" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- KPI Cards -->
                <RowDefinition Height="Auto"/> <!-- Alerts Section -->
                <RowDefinition Height="Auto"/> <!-- AI Insights & Drill-Down (Phase 3) -->
                <RowDefinition Height="Auto"/> <!-- Main Content Grid -->
                <RowDefinition Height="Auto"/> <!-- Audit Trail (Phase 3) -->
                <RowDefinition Height="Auto"/> <!-- Export & Analytics (Phase 3) -->
                <RowDefinition Height="*"/>    <!-- Flexible space -->
            </Grid.RowDefinitions>

            <!-- Header with Refresh + KPI scope filters -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="DashboardHeader" Text="Admin Dashboard" FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,4"/>
                        <TextBlock x:Name="DashboardSubtitle" Text="Control center for document management and team oversight"
                                   FontSize="13" Foreground="{DynamicResource DimForeground}"/>
                    </StackPanel>
                    <Button x:Name="RefreshBtn" Grid.Column="1" Content="🔄 Refresh" Padding="12,8" Margin="0,0,12,0"
                            Background="#17A2B8" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Command="{Binding RefreshCommand}"
                            ToolTip="Refresh dashboard data" FontWeight="SemiBold"/>
                    <ComboBox x:Name="TimeRangeCombo" Grid.Column="2" MinWidth="170" MaxWidth="220"
                              SelectedItem="{Binding SelectedTimeRange, Mode=TwoWay}"
                              ToolTip="Select time range for metrics"/>
                </Grid>
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Branch" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{DynamicResource DimForeground}"/>
                    <ComboBox x:Name="BranchFilterCombo" Width="200" Margin="0,0,16,0"
                              SelectionChanged="BranchSectionFilter_Changed"
                              ToolTip="Limit KPIs and document lists to a branch (All = no filter)"/>
                    <TextBlock Text="Section" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{DynamicResource DimForeground}"/>
                    <ComboBox x:Name="SectionFilterCombo" Width="180"
                              SelectionChanged="BranchSectionFilter_Changed"
                              ToolTip="Limit KPIs and document lists to a section (All = no filter)"/>
                </StackPanel>
            </Grid>

            <!-- KPI Cards -->
            <Border Grid.Row="1" Background="{DynamicResource ContentBackground}" Padding="20" Margin="0,0,0,16"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="Key Performance Indicators" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- KPI Card 1: Active Issues -->
                        <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource PanelBackground}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                                Padding="16" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="🔴 Active Issues" FontSize="12" Foreground="{DynamicResource DimForeground}" Margin="0,0,0,8"/>
                                <TextBlock x:Name="KpiActiveIssues" Text="0" FontSize="28" FontWeight="Bold"
                                           Foreground="#DC3545" Margin="0,0,0,4"/>
                                <TextBlock x:Name="KpiActiveIssuesChange" Text="—" FontSize="11"
                                           Foreground="{DynamicResource DimForeground}"/>
                            </StackPanel>
                        </Border>

                        <!-- KPI Card 2: Pending Tasks -->
                        <Border Grid.Row="0" Grid.Column="1" Background="{DynamicResource PanelBackground}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                                Padding="16" Margin="3,0">
                            <StackPanel>
                                <TextBlock Text="👥 Pending Tasks" FontSize="12" Foreground="{DynamicResource DimForeground}" Margin="0,0,0,8"/>
                                <TextBlock x:Name="KpiPendingTasks" Text="0" FontSize="28" FontWeight="Bold"
                                           Foreground="#FFC107" Margin="0,0,0,4"/>
                                <TextBlock x:Name="KpiPendingTasksChange" Text="—" FontSize="11"
                                           Foreground="{DynamicResource DimForeground}"/>
                            </StackPanel>
                        </Border>

                        <!-- KPI Card 3: Overdue Items -->
                        <Border Grid.Row="0" Grid.Column="2" Background="{DynamicResource PanelBackground}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                                Padding="16" Margin="3,0">
                            <StackPanel>
                                <TextBlock Text="⚠️ Overdue Items" FontSize="12" Foreground="{DynamicResource DimForeground}" Margin="0,0,0,8"/>
                                <TextBlock x:Name="KpiOverdueItems" Text="0" FontSize="28" FontWeight="Bold"
                                           Foreground="#DC3545" Margin="0,0,0,4"/>
                                <TextBlock x:Name="KpiOverdueItemsChange" Text="—" FontSize="11"
                                           Foreground="{DynamicResource DimForeground}"/>
                            </StackPanel>
                        </Border>

                        <!-- KPI Card 4: Completion Rate -->
                        <Border Grid.Row="0" Grid.Column="3" Background="{DynamicResource PanelBackground}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                                Padding="16" Margin="6,0,0,0">
                            <StackPanel>
                                <TextBlock Text="✅ Completion Rate" FontSize="12" Foreground="{DynamicResource DimForeground}" Margin="0,0,0,8"/>
                                <TextBlock x:Name="KpiCompletionRate" Text="0%" FontSize="28" FontWeight="Bold"
                                           Foreground="#28A745" Margin="0,0,0,4"/>
                                <TextBlock x:Name="KpiCompletionRateChange" Text="—" FontSize="11"
                                           Foreground="{DynamicResource DimForeground}"/>
                            </StackPanel>
                        </Border>

                        <!-- Second Row KPIs -->
                        <!-- KPI Card 5: Avg Response Time -->
                        <Border Grid.Row="2" Grid.Column="0" Background="{DynamicResource PanelBackground}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                                Padding="16" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="⏱️ Avg Response Time" FontSize="12" Foreground="{DynamicResource DimForeground}" Margin="0,0,0,8"/>
                                <TextBlock x:Name="KpiAvgResponseTime" Text="—" FontSize="28" FontWeight="Bold"
                                           Foreground="#17A2B8" Margin="0,0,0,4"/>
                                <TextBlock x:Name="KpiAvgResponseTimeChange" Text="—" FontSize="11"
                                           Foreground="{DynamicResource DimForeground}"/>
                            </StackPanel>
                        </Border>

                        <!-- KPI Card 6: Daily Throughput -->
                        <Border Grid.Row="2" Grid.Column="1" Background="{DynamicResource PanelBackground}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                                Padding="16" Margin="3,0">
                            <StackPanel>
                                <TextBlock Text="📈 Daily Throughput" FontSize="12" Foreground="{DynamicResource DimForeground}" Margin="0,0,0,8"/>
                                <TextBlock x:Name="KpiDailyThroughput" Text="0" FontSize="28" FontWeight="Bold"
                                           Foreground="#6C757D" Margin="0,0,0,4"/>
                                <TextBlock x:Name="KpiDailyThroughputChange" Text="—" FontSize="11"
                                           Foreground="{DynamicResource DimForeground}"/>
                            </StackPanel>
                        </Border>

                        <!-- KPI Card 7: Documents by Status -->
                        <Border Grid.Row="2" Grid.Column="2" Background="{DynamicResource PanelBackground}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                                Padding="16" Margin="3,0">
                            <StackPanel>
                                <TextBlock Text="📊 Total Documents" FontSize="12" Foreground="{DynamicResource DimForeground}" Margin="0,0,0,8"/>
                                <TextBlock x:Name="KpiTotalDocuments" Text="0" FontSize="28" FontWeight="Bold"
                                           Foreground="#0E639C" Margin="0,0,0,4"/>
                                <TextBlock x:Name="KpiTotalDocumentsChange" Text="—" FontSize="11"
                                           Foreground="{DynamicResource DimForeground}"/>
                            </StackPanel>
                        </Border>

                        <!-- KPI Card 8: Follow-ups Due -->
                        <Border Grid.Row="2" Grid.Column="3" Background="{DynamicResource PanelBackground}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                                Padding="16" Margin="6,0,0,0">
                            <StackPanel>
                                <TextBlock Text="🔔 Follow-ups Due" FontSize="12" Foreground="{DynamicResource DimForeground}" Margin="0,0,0,8"/>
                                <TextBlock x:Name="KpiFollowUpsDue" Text="0" FontSize="28" FontWeight="Bold"
                                           Foreground="#FD7E14" Margin="0,0,0,4"/>
                                <TextBlock x:Name="KpiFollowUpsDueChange" Text="—" FontSize="11"
                                           Foreground="{DynamicResource DimForeground}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    <views:TeamTasksPanel x:Name="TeamTasksSection"/>
                </StackPanel>
            </Border>

            <!-- Smart Alerts Section -->
            <Border Grid.Row="2" x:Name="AlertsPanel" Background="#FFF3CD" BorderBrush="#FFC107" BorderThickness="1"
                    Padding="16" Margin="0,0,0,16" CornerRadius="4" Visibility="Collapsed">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="⚠️ Smart Alerts &amp; Notifications" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#856404" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Dismiss All" Padding="8,4"
                                Background="Transparent" Foreground="#856404" BorderBrush="#856404" BorderThickness="1"
                                Cursor="Hand" Click="DismissAlerts_Click"/>
                    </Grid>
                    <ItemsControl x:Name="AlertsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" BorderBrush="#FFC107" BorderThickness="1" CornerRadius="3"
                                        Padding="10,8" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Message}" TextWrapping="Wrap"
                                                   Foreground="#856404" VerticalAlignment="Center"/>
                                        <Button Grid.Column="2" Content="View" Padding="6,3" Margin="8,0,0,0"
                                                Background="#FFC107" Foreground="White" BorderThickness="0" Cursor="Hand"
                                                Click="ViewAlert_Click" Tag="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Advanced Sections (Phase 3) -->
            <Grid Grid.Row="3" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- AI-Powered Insights -->
                <Border Grid.Column="0" Background="{DynamicResource ContentBackground}" Padding="16"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="💡 AI-Powered Insights" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,12"/>
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3"
                                Background="{DynamicResource AlternateRowBackground}" Padding="12" Margin="0,0,0,8">
                            <TextBlock x:Name="AiSummaryText" Text="Loading insights..." TextWrapping="Wrap"
                                       FontSize="11" Foreground="{DynamicResource PrimaryForeground}" LineHeight="16"/>
                        </Border>
                        <TextBlock Text="Recommendations:" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,6"/>
                        <ItemsControl x:Name="AiRecommendationsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,4" Margin="0,0,0,4" Background="{DynamicResource ContentBackground}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3">
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="11"
                                                   Foreground="{DynamicResource PrimaryForeground}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Branch/Section Drill-Down -->
                <Border Grid.Column="2" Background="{DynamicResource ContentBackground}" Padding="16"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🏢 Branch/Section Analysis" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryForeground}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" x:Name="DrillDownModeCombo" Width="100"
                                      SelectionChanged="DrillDownMode_Changed"/>
                        </Grid>
                        <DataGrid x:Name="DrillDownGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" CanUserAddRows="False" GridLinesVisibility="Horizontal"
                                  Background="Transparent" BorderThickness="0" MaxHeight="250"
                                  RowBackground="{DynamicResource AlternateRowBackground}"
                                  AlternatingRowBackground="{DynamicResource ContentBackground}"
                                  SelectionChanged="DrillDownGrid_SelectionChanged"
                                  MouseDoubleClick="DrillDownGrid_DoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Total" Binding="{Binding TotalCount}" Width="60"/>
                                <DataGridTextColumn Header="Issues" Binding="{Binding IssueCount}" Width="60">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#DC3545"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Cleared" Binding="{Binding ClearedCount}" Width="60">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#28A745"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Button x:Name="DrillDownBtn" Content="View Details" Padding="10,6" Margin="0,12,0,0"
                                Background="#0E639C" Foreground="White" BorderThickness="0" Cursor="Hand"
                                Click="DrillDownBtn_Click" IsEnabled="False" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Main Content Grid: 3 Columns -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column: Critical Issues & Activity Feed -->
                <StackPanel Grid.Column="0">
                    <!-- Critical Issues Management -->
                    <Border Background="{DynamicResource ContentBackground}" Padding="16" Margin="0,0,0,16"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🔴 Critical Issues" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryForeground}" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1" x:Name="IssueSeverityFilter" Width="120"
                                          SelectionChanged="IssueSeverityFilter_Changed"/>
                            </Grid>
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3"
                                    MaxHeight="350">
                                <ListBox x:Name="CriticalIssuesList" Background="Transparent" BorderThickness="0"
                                         SelectionChanged="CriticalIssuesList_SelectionChanged"
                                         MouseDoubleClick="CriticalIssuesList_DoubleClick">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,8" Margin="0,0,0,4" Background="{DynamicResource AlternateRowBackground}"
                                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12"
                                                                   Foreground="{DynamicResource PrimaryForeground}" TextWrapping="Wrap"/>
                                                        <Border Grid.Column="1" Background="{Binding SeverityColor}" CornerRadius="3"
                                                                Padding="6,2" Margin="8,0,0,0">
                                                            <TextBlock Text="{Binding Severity}" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                                                        </Border>
                                                    </Grid>
                                                    <TextBlock Text="{Binding Details}" FontSize="11" Foreground="{DynamicResource DimForeground}"
                                                               Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding AssigneeInfo}" FontSize="10" Foreground="{DynamicResource SecondaryForeground}"
                                                               Margin="0,4,0,0" FontStyle="Italic"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button x:Name="ResolveIssueBtn" Content="Mark Resolved" Padding="10,6" Margin="0,0,6,0"
                                        Background="#28A745" Foreground="White" BorderThickness="0" Cursor="Hand"
                                        Click="ResolveIssue_Click" IsEnabled="False"/>
                                <Button x:Name="ReassignIssueBtn" Content="Reassign" Padding="10,6" Margin="0,0,6,0"
                                        Background="#17A2B8" Foreground="White" BorderThickness="0" Cursor="Hand"
                                        Click="ReassignIssue_Click" IsEnabled="False"/>
                                <Button x:Name="ViewIssueDetailsBtn" Content="View Details" Padding="10,6"
                                        Background="#6C757D" Foreground="White" BorderThickness="0" Cursor="Hand"
                                        Click="ViewIssueDetails_Click" IsEnabled="False"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Activity Feed -->
                    <Border Background="{DynamicResource ContentBackground}" Padding="16"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="📋 Live Activity Feed" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryForeground}" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="Clear" Padding="8,4"
                                        Background="Transparent" Foreground="{DynamicResource DimForeground}"
                                        BorderThickness="0" Cursor="Hand" Click="ClearActivityFeed_Click"/>
                            </Grid>
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3"
                                    MaxHeight="400">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="ActivityFeed">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="8,6" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Top"/>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="11"
                                                                       Foreground="{DynamicResource PrimaryForeground}"/>
                                                            <TextBlock Text="{Binding TimeAgo}" FontSize="10" Foreground="{DynamicResource DimForeground}"
                                                                       Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Middle Column: Team Workload & Document Flow -->
                <StackPanel Grid.Column="2">
                    <!-- Team Workload -->
                    <Border Background="{DynamicResource ContentBackground}" Padding="16" Margin="0,0,0,16"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="👥 Team Workload" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,12"/>
                            <DataGrid x:Name="TeamWorkloadGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                      HeadersVisibility="Column" CanUserAddRows="False" GridLinesVisibility="Horizontal"
                                      Background="Transparent" BorderThickness="0" MaxHeight="280"
                                      RowBackground="{DynamicResource AlternateRowBackground}"
                                      AlternatingRowBackground="{DynamicResource ContentBackground}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="User" Binding="{Binding Username}" Width="*"/>
                                    <DataGridTextColumn Header="Pending" Binding="{Binding PendingCount}" Width="60"/>
                                    <DataGridTextColumn Header="In Progress" Binding="{Binding InProgressCount}" Width="80"/>
                                    <DataGridTextColumn Header="Overdue" Binding="{Binding OverdueCount}" Width="65">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#DC3545"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            <Button x:Name="ManageAssignmentsBtn" Content="Manage Assignments" Padding="10,6" Margin="0,12,0,0"
                                    Background="#0E639C" Foreground="White" BorderThickness="0" Cursor="Hand"
                                    Click="ManageAssignments_Click" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <!-- Document Flow Visualization -->
                    <Border Background="{DynamicResource ContentBackground}" Padding="16"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="📊 Document Pipeline" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,12"/>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>

                                <!-- Draft -->
                                <Border Grid.Row="0" Grid.Column="0" Background="#E9ECEF" CornerRadius="3" Padding="10,8" Margin="0,0,0,8">
                                    <TextBlock Text="📝 Draft" FontSize="12" FontWeight="SemiBold" Foreground="#495057"/>
                                </Border>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="PipelineDraft" Text="0" FontSize="18"
                                           FontWeight="Bold" Foreground="#495057" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <!-- Reviewed -->
                                <Border Grid.Row="1" Grid.Column="0" Background="#D1ECF1" CornerRadius="3" Padding="10,8" Margin="0,0,0,8">
                                    <TextBlock Text="👁️ Reviewed" FontSize="12" FontWeight="SemiBold" Foreground="#0C5460"/>
                                </Border>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="PipelineReviewed" Text="0" FontSize="18"
                                           FontWeight="Bold" Foreground="#0C5460" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <!-- Ready for Audit -->
                                <Border Grid.Row="2" Grid.Column="0" Background="#D4EDDA" CornerRadius="3" Padding="10,8" Margin="0,0,0,8">
                                    <TextBlock Text="✅ Ready for Audit" FontSize="12" FontWeight="SemiBold" Foreground="#155724"/>
                                </Border>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="PipelineReady" Text="0" FontSize="18"
                                           FontWeight="Bold" Foreground="#155724" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <!-- Issue -->
                                <Border Grid.Row="3" Grid.Column="0" Background="#F8D7DA" CornerRadius="3" Padding="10,8" Margin="0,0,0,8">
                                    <TextBlock Text="⚠️ Issue Found" FontSize="12" FontWeight="SemiBold" Foreground="#721C24"/>
                                </Border>
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="PipelineIssue" Text="0" FontSize="18"
                                           FontWeight="Bold" Foreground="#721C24" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <!-- Cleared -->
                                <Border Grid.Row="4" Grid.Column="0" Background="#D1E7DD" CornerRadius="3" Padding="10,8">
                                    <TextBlock Text="🎉 Cleared" FontSize="12" FontWeight="SemiBold" Foreground="#0F5132"/>
                                </Border>
                                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="PipelineCleared" Text="0" FontSize="18"
                                           FontWeight="Bold" Foreground="#0F5132" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right Column: Follow-ups & Quick Actions -->
                <StackPanel Grid.Column="4">
                    <!-- Follow-Up Center -->
                    <Border Background="{DynamicResource ContentBackground}" Padding="16" Margin="0,0,0,16"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🔔 Follow-Up Center" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryForeground}" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1" x:Name="FollowUpFilter" Width="100"
                                          SelectionChanged="FollowUpFilter_Changed"/>
                            </Grid>
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3"
                                    MaxHeight="280">
                                <ListBox x:Name="FollowUpsList" Background="Transparent" BorderThickness="0"
                                         SelectionChanged="FollowUpsList_SelectionChanged"
                                         MouseDoubleClick="FollowUpsList_DoubleClick">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="8,6" Margin="0,0,0,4" Background="{DynamicResource AlternateRowBackground}"
                                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DocumentName}" FontWeight="SemiBold" FontSize="11"
                                                               Foreground="{DynamicResource PrimaryForeground}" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding DueInfo}" FontSize="10" Foreground="{Binding DueColor}"
                                                               Margin="0,2,0,0" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding AssignedTo}" FontSize="10" Foreground="{DynamicResource DimForeground}"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button x:Name="SendReminderBtn" Content="Send Reminder" Padding="10,6" Margin="0,0,6,0"
                                        Background="#FFC107" Foreground="White" BorderThickness="0" Cursor="Hand"
                                        Click="SendReminder_Click" IsEnabled="False"/>
                                <Button x:Name="ViewFollowUpBtn" Content="View" Padding="10,6"
                                        Background="#6C757D" Foreground="White" BorderThickness="0" Cursor="Hand"
                                        Click="ViewFollowUp_Click" IsEnabled="False"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Quick Actions Panel -->
                    <Border Background="{DynamicResource ContentBackground}" Padding="16"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="⚡ Quick Actions" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,12"/>
                            <Button Content="➕ Bulk Assign Documents" Padding="12,8" Margin="0,0,0,8"
                                    Background="#28A745" Foreground="White" BorderThickness="0" Cursor="Hand"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Click="BulkAssign_Click"/>
                            <Button Content="📧 Send Team Reminders" Padding="12,8" Margin="0,0,0,8"
                                    Background="#17A2B8" Foreground="White" BorderThickness="0" Cursor="Hand"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Click="SendTeamReminders_Click"/>
                            <Button Content="📊 Generate Report" Padding="12,8" Margin="0,0,0,8"
                                    Background="#6610F2" Foreground="White" BorderThickness="0" Cursor="Hand"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Click="GenerateReport_Click"/>
                            <Button Content="👥 Manage Users" Padding="12,8" Margin="0,0,0,8"
                                    Background="#FD7E14" Foreground="White" BorderThickness="0" Cursor="Hand"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Click="ManageUsers_Click"/>
                            <Button Content="⚙️ Control Panel" Padding="12,8" Margin="0,0,0,8"
                                    Background="#6C757D" Foreground="White" BorderThickness="0" Cursor="Hand"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Click="ControlPanel_Click"/>
                            <Button Content="🔍 Advanced Search" Padding="12,8"
                                    Background="#0E639C" Foreground="White" BorderThickness="0" Cursor="Hand"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Click="AdvancedSearch_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Audit Trail & Compliance Monitoring (Phase 3) -->
            <Expander Grid.Row="5" Header="📜 Recent Audit Trail &amp; Compliance" IsExpanded="False" Margin="0,16,0,0"
                      Background="{DynamicResource ContentBackground}" Padding="12"
                      BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <StackPanel Margin="0,8,0,0">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Recent audit log entries (last 50):" FontSize="11"
                                   Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="View Full Log" Padding="8,4"
                                Background="#6C757D" Foreground="White" BorderThickness="0" Cursor="Hand"
                                Click="ViewFullAuditLog_Click"/>
                    </Grid>
                    <DataGrid x:Name="AuditTrailGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" CanUserAddRows="False" GridLinesVisibility="Horizontal"
                              Background="Transparent" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                              MaxHeight="200" RowBackground="{DynamicResource AlternateRowBackground}"
                              AlternatingRowBackground="{DynamicResource ContentBackground}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Timestamp" Binding="{Binding FormattedTimestamp}" Width="140"/>
                            <DataGridTextColumn Header="User" Binding="{Binding Username}" Width="100"/>
                            <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="150"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="100"/>
                            <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Expander>

            <!-- Export & Analytics (Phase 3) -->
            <Border Grid.Row="6" Background="{DynamicResource ContentBackground}" Padding="16" Margin="0,16,0,0"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                <StackPanel>
                    <TextBlock Text="📊 Export &amp; Analytics" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,12"/>
                    <WrapPanel>
                        <Button Content="📥 Export Dashboard (Excel)" Padding="12,8" Margin="0,0,8,0"
                                Background="#28A745" Foreground="White" BorderThickness="0" Cursor="Hand"
                                Click="ExportDashboardExcel_Click"/>
                        <Button Content="📄 Export Dashboard (PDF)" Padding="12,8" Margin="0,0,8,0"
                                Background="#DC3545" Foreground="White" BorderThickness="0" Cursor="Hand"
                                Click="ExportDashboardPDF_Click"/>
                        <Button Content="📈 Performance Analytics" Padding="12,8" Margin="0,0,8,0"
                                Background="#6610F2" Foreground="White" BorderThickness="0" Cursor="Hand"
                                Click="ViewPerformanceAnalytics_Click"/>
                        <Button Content="📊 Trend Analysis" Padding="12,8" Margin="0,0,8,0"
                                Background="#17A2B8" Foreground="White" BorderThickness="0" Cursor="Hand"
                                Click="ViewTrendAnalysis_Click"/>
                        <Button Content="⚙️ Advanced Filters..." Padding="12,8"
                                Background="#FD7E14" Foreground="White" BorderThickness="0" Cursor="Hand"
                                Click="ShowAdvancedFilters_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
