<UserControl x:Class="WorkAudit.Views.InputView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{DynamicResource PanelBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Shared Branch, Date, type, and section for Import and Webcam -->
        <Grid x:Name="SharedMetadataPanel" Grid.Row="0" Margin="8,8,8,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <TextBlock x:Name="InputBranchLabel" Text="Branch" Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="0,0,8,0" Width="50"/>
                <ComboBox x:Name="BranchCombo" MinWidth="160" Padding="8,6" VerticalContentAlignment="Center"/>
                <TextBlock x:Name="InputDateLabel" Text="Date" Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="16,0,8,0" Width="35"/>
                <DatePicker x:Name="DocumentDatePicker" MinWidth="120" Padding="8,6" VerticalContentAlignment="Center"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock x:Name="InputDocumentTypeLabel" Text="Document type" Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="0,0,8,0" Width="90"/>
                <ComboBox x:Name="DocumentTypeCombo" MinWidth="200" Padding="8,6" VerticalContentAlignment="Center"/>
                <TextBlock x:Name="InputSectionLabel" Text="Section" Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="16,0,8,0" Width="55"/>
                <ComboBox x:Name="SectionCombo" MinWidth="140" Padding="8,6" VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>
    <TabControl Grid.Row="1" x:Name="InputTabs" Background="{DynamicResource PanelBackground}" SelectedIndex="0">
        <TabControl.Resources>
            <Style TargetType="TabItem">
                <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}"/>
                <Setter Property="Padding" Value="20,10"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,2"
                                    Padding="{TemplateBinding Padding}" Margin="0,0,4,0">
                                <ContentPresenter ContentSource="Header"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Border" Property="BorderBrush" Value="#0E639C"/>
                                    <Setter TargetName="Border" Property="BorderThickness" Value="0,0,0,2"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="{DynamicResource HoverBackground}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </TabControl.Resources>
        <TabItem x:Name="ImportTab" Header="Import">
            <ContentControl x:Name="ImportHost"/>
        </TabItem>
        <TabItem x:Name="WebcamTab" Header="Webcam">
            <ContentControl x:Name="WebcamHost"/>
        </TabItem>
    </TabControl>
    </Grid>
</UserControl>
