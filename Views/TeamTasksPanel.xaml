<UserControl x:Class="WorkAudit.Views.TeamTasksPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border x:Name="PanelBorder" Background="{DynamicResource ContentBackground}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,16,0,0"
            Visibility="Collapsed">
        <StackPanel>
            <TextBlock x:Name="SectionTitle" Text="My team tasks" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryForeground}" Margin="0,0,0,4"/>
            <TextBlock x:Name="SectionSubtitle" Text="" FontSize="11" Foreground="{DynamicResource DimForeground}" Margin="0,0,0,12"/>
            <ItemsControl x:Name="TasksItems">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource PanelBackground}" Margin="0,0,0,8" Padding="10,8"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0"
                                          IsChecked="{Binding IsCompleted}"
                                          Click="TaskCheck_Click"/>
                                <Border Grid.Column="1" Background="Transparent" Cursor="Hand" Padding="2,0,0,0"
                                        MouseLeftButtonDown="TaskBody_MouseLeftButtonDown"
                                        ToolTip="{Binding NoteTooltip}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource PrimaryForeground}"/>
                                        <TextBlock Text="{Binding DetailLine}" FontSize="11" Foreground="{DynamicResource DimForeground}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock x:Name="EmptyText" Text="No team tasks for this period." FontSize="12"
                       Foreground="{DynamicResource DimForeground}" Visibility="Collapsed"/>
        </StackPanel>
    </Border>
</UserControl>
