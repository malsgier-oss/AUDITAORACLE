<Window x:Class="WorkAudit.Views.Admin.TeamTaskEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Team task" Height="460" Width="480" MinHeight="400" MinWidth="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ContentBackground}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="LabelTitle" Grid.Row="0" Text="Title:" Margin="0,0,0,4"/>
        <TextBox x:Name="TitleBox" Grid.Row="1" Margin="0,0,0,12" Padding="6"/>

        <TextBlock x:Name="LabelDescription" Grid.Row="2" Text="Description (optional):" Margin="0,0,0,4"/>
        <TextBox x:Name="DescriptionBox" Grid.Row="3" Height="72" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12" Padding="6"/>

        <TextBlock x:Name="LabelAssignee" Grid.Row="4" Text="Assign to:" Margin="0,0,0,4"/>
        <ComboBox x:Name="UserCombo" Grid.Row="5" Margin="0,0,0,12" DisplayMemberPath="DisplayName"/>

        <Grid Grid.Row="6" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="LabelRecurrence" Grid.Row="0" Grid.Column="0" Text="Recurrence:" Margin="0,0,0,4"/>
            <ComboBox x:Name="RecurrenceCombo" Grid.Row="1" Grid.Column="0"/>
            <TextBlock x:Name="LabelActive" Grid.Row="0" Grid.Column="2" Text="Active:" Margin="0,0,0,4"/>
            <CheckBox x:Name="ActiveCheck" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" IsChecked="True"/>
        </Grid>

        <Grid Grid.Row="7" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="LabelStart" Grid.Row="0" Grid.Column="0" Text="Start date:" Margin="0,0,0,4"/>
            <DatePicker x:Name="StartDatePicker" Grid.Row="1" Grid.Column="0"/>
            <TextBlock x:Name="LabelEnd" Grid.Row="0" Grid.Column="2" Text="End date (optional):" Margin="0,0,0,4"/>
            <DatePicker x:Name="EndDatePicker" Grid.Row="1" Grid.Column="2"/>
        </Grid>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OkBtn" Content="OK" Padding="16,8" Margin="0,0,8,0" IsDefault="True" Click="OkBtn_Click"
                    Background="#0E639C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="CancelBtn" Content="Cancel" Padding="16,8" IsCancel="True" Click="CancelBtn_Click"
                    Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource DimForeground}" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
