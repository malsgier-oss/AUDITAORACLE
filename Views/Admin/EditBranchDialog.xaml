<Window x:Class="WorkAudit.Views.Admin.EditBranchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Branch" Height="260" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource ContentBackground}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Name:" VerticalAlignment="Center"/>
        <TextBox Grid.Column="1" x:Name="NameBox" Padding="6,4"/>

        <TextBlock Grid.Row="1" Text="Code:" VerticalAlignment="Center" Margin="0,12,0,0"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="CodeBox" Width="80" HorizontalAlignment="Left" Padding="6,4" Margin="0,12,0,0"/>

        <TextBlock Grid.Row="2" Text="Display order:" VerticalAlignment="Center" Margin="0,12,0,0"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="OrderBox" Width="60" HorizontalAlignment="Left" Padding="6,4" Margin="0,12,0,0"/>

        <CheckBox Grid.Row="3" Grid.Column="1" x:Name="ActiveCheck" Content="Active" IsChecked="True" VerticalAlignment="Top" Margin="0,12,0,0"/>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="SaveBtn" Content="Save" Padding="16,8" Margin="0,0,8,0" Click="Save_Click"
                    Background="#0E639C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="CancelBtn" Content="Cancel" Padding="16,8" Click="Cancel_Click"
                    Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
