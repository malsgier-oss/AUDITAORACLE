<Window x:Class="WorkAudit.Views.Admin.ControlPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Control Panel - AUDITA"
        Height="650" Width="900" MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PanelBackground}"
        PreviewKeyDown="ControlPanelWindow_PreviewKeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#0E639C" Padding="16,12">
            <StackPanel>
                <TextBlock x:Name="HeaderTitle" Text="Control Panel" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock x:Name="HeaderSubtitle" Text="Configure document types, branches, security, and system settings" FontSize="12" Foreground="#CCCCCC" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Margin="16" x:Name="MainTabControl">
            <!-- General Tab -->
            <TabItem x:Name="GeneralTab" Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel Margin="8">
                        <TextBlock x:Name="AppLanguageSectionTitle" Text="Application Language" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource DimForeground}" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="LanguageLabel" Text="Language:" VerticalAlignment="Center" Width="80"/>
                                <ComboBox x:Name="ReportLanguageCombo" Width="120" Margin="4,0,0,0"/>
                            </StackPanel>
                            <TextBlock x:Name="AppLanguageDescription" Grid.Column="1" Text="Language for the entire application (menus, views, reports). English or Arabic." 
                                       Foreground="{DynamicResource DimForeground}" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0" TextWrapping="Wrap"/>
                        </Grid>

                        <TextBlock x:Name="AppearanceSectionTitle" Text="Appearance" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource DimForeground}" Margin="0,16,0,12"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="ThemeLabel" Text="Theme:" VerticalAlignment="Center" Width="80"/>
                                <ComboBox x:Name="ThemeCombo" Width="160" Margin="4,0,0,0"/>
                            </StackPanel>
                            <TextBlock x:Name="ThemeDescription" Grid.Column="1" Text="Light or Dark Midnight color theme. Changes apply immediately." 
                                       Foreground="{DynamicResource DimForeground}" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0" TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Keyboard shortcuts tab -->
            <TabItem x:Name="ShortcutsTab" Header="Shortcuts">
                <DockPanel Margin="8">
                    <TextBlock x:Name="ShortcutsIntroText" DockPanel.Dock="Top" TextWrapping="Wrap" Margin="0,0,0,8"
                               Foreground="{DynamicResource DimForeground}" FontSize="11"/>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button x:Name="ResetKeyboardShortcutsBtn" Content="Reset all to defaults" Padding="12,6" Margin="0,0,8,0" Click="ResetKeyboardShortcuts_Click"
                                Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="ShortcutsRowsPanel"/>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- Document Types Tab -->
            <TabItem x:Name="DocTypesTab" Header="Document Types">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button x:Name="AddDocTypeBtn" Content="Add New" Padding="12,6" Margin="0,0,8,0" Click="AddDocType_Click"
                                Background="#0E639C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        <Button x:Name="EditDocTypeBtn" Content="Edit" Padding="12,6" Margin="0,0,8,0" Click="EditDocType_Click"
                                Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand" IsEnabled="False"/>
                        <Button x:Name="DeleteDocTypeBtn" Content="Delete" Padding="12,6" Margin="0,0,8,0" Click="DeleteDocType_Click"
                                Background="{DynamicResource ButtonSecondaryBackground}" Foreground="#C50F1F" BorderThickness="0" Cursor="Hand" IsEnabled="False"/>
                        <CheckBox x:Name="ShowInactiveDocTypes" Content="Show inactive" VerticalAlignment="Center" Margin="16,0,0,0"
                                  Checked="ShowInactiveDocTypes_Changed" Unchecked="ShowInactiveDocTypes_Changed"/>
                    </StackPanel>
                    <DataGrid Grid.Row="1" x:Name="DocTypesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single" SelectionChanged="DocTypesGrid_SelectionChanged"
                              Background="{DynamicResource ContentBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource BorderBrush}">
                        <DataGrid.Columns>
                            <DataGridTextColumn x:Name="DocTypesColBranch" Header="Branch" Binding="{Binding Branch}" Width="120"/>
                            <DataGridTextColumn x:Name="DocTypesColSection" Header="Section" Binding="{Binding Section}" Width="100"/>
                            <DataGridTextColumn x:Name="DocTypesColName" Header="Name" Binding="{Binding Name}" Width="*" MinWidth="150"/>
                            <DataGridTextColumn x:Name="DocTypesColKeywords" Header="Keywords" Binding="{Binding Keywords}" Width="200"/>
                            <DataGridCheckBoxColumn x:Name="DocTypesColActive" Header="Active" Binding="{Binding IsActive}" Width="60"/>
                            <DataGridTextColumn x:Name="DocTypesColOrder" Header="Order" Binding="{Binding DisplayOrder}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Grid.Row="2" x:Name="DocTypesCountLabel" Text="0 document types" Foreground="{DynamicResource DimForeground}" FontSize="11" Margin="0,8,0,0"/>
                </Grid>
            </TabItem>

            <!-- Branches Tab -->
            <TabItem x:Name="BranchesTab" Header="Branches">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button x:Name="AddBranchBtn" Content="Add New" Padding="12,6" Margin="0,0,8,0" Click="AddBranch_Click"
                                Background="#0E639C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        <Button x:Name="EditBranchBtn" Content="Edit" Padding="12,6" Margin="0,0,8,0" Click="EditBranch_Click"
                                Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand" IsEnabled="False"/>
                        <Button x:Name="DeleteBranchBtn" Content="Delete" Padding="12,6" Click="DeleteBranch_Click"
                                Background="{DynamicResource ButtonSecondaryBackground}" Foreground="#C50F1F" BorderThickness="0" Cursor="Hand" IsEnabled="False"/>
                    </StackPanel>
                    <DataGrid Grid.Row="1" x:Name="BranchesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single" SelectionChanged="BranchesGrid_SelectionChanged"
                              Background="{DynamicResource ContentBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource BorderBrush}">
                        <DataGrid.Columns>
                            <DataGridTextColumn x:Name="BranchesColName" Header="Name" Binding="{Binding Name}" Width="*" MinWidth="150"/>
                            <DataGridTextColumn x:Name="BranchesColCode" Header="Code" Binding="{Binding Code}" Width="100"/>
                            <DataGridCheckBoxColumn x:Name="BranchesColActive" Header="Active" Binding="{Binding IsActive}" Width="60"/>
                            <DataGridTextColumn x:Name="BranchesColOrder" Header="Order" Binding="{Binding DisplayOrder}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Grid.Row="2" x:Name="BranchesCountLabel" Text="0 branches" Foreground="{DynamicResource DimForeground}" FontSize="11" Margin="0,8,0,0"/>
                </Grid>
            </TabItem>

            <!-- Security Settings Tab -->
            <TabItem x:Name="SecurityTab" Header="Security">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel Margin="8">
                        <TextBlock Text="Session Settings" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource DimForeground}" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Session timeout (minutes):" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="SessionTimeoutBox" Width="80" HorizontalAlignment="Left" Padding="6,4"/>
                            <TextBlock Grid.Column="2" Text="Time before inactive session expires" Foreground="{DynamicResource DimForeground}" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>

                            <TextBlock Grid.Row="1" Text="Session expiry (hours):" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="SessionExpiryBox" Width="80" HorizontalAlignment="Left" Padding="6,4" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Maximum session duration" Foreground="{DynamicResource DimForeground}" FontSize="11" VerticalAlignment="Center" Margin="8,8,0,0"/>

                            <TextBlock Grid.Row="2" Text="Max login attempts:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="MaxLoginAttemptsBox" Width="80" HorizontalAlignment="Left" Padding="6,4" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="Failed attempts before lockout" Foreground="{DynamicResource DimForeground}" FontSize="11" VerticalAlignment="Center" Margin="8,8,0,0"/>

                            <TextBlock Grid.Row="3" Text="Lockout duration (minutes):" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="3" Grid.Column="1" x:Name="LockoutDurationBox" Width="80" HorizontalAlignment="Left" Padding="6,4" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="Account lockout duration" Foreground="{DynamicResource DimForeground}" FontSize="11" VerticalAlignment="Center" Margin="8,8,0,0"/>
                        </Grid>

                        <Separator Margin="0,8,0,16"/>
                        <TextBlock Text="Password Policy" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource DimForeground}" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Minimum length:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="PasswordMinLengthBox" Width="80" HorizontalAlignment="Left" Padding="6,4"/>

                            <TextBlock Grid.Row="1" Text="Require uppercase:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <CheckBox Grid.Row="1" Grid.Column="1" x:Name="PasswordUppercaseCheck" VerticalAlignment="Center" Margin="0,8,0,0"/>

                            <TextBlock Grid.Row="2" Text="Require lowercase:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <CheckBox Grid.Row="2" Grid.Column="1" x:Name="PasswordLowercaseCheck" VerticalAlignment="Center" Margin="0,8,0,0"/>

                            <TextBlock Grid.Row="3" Text="Require digit:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <CheckBox Grid.Row="3" Grid.Column="1" x:Name="PasswordDigitCheck" VerticalAlignment="Center" Margin="0,8,0,0"/>

                            <TextBlock Grid.Row="4" Text="Require special character:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <CheckBox Grid.Row="4" Grid.Column="1" x:Name="PasswordSpecialCheck" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Workflow Tab -->
            <TabItem x:Name="WorkflowTab" Header="Workflow">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel Margin="8">
                        <TextBlock Text="Document Workflow" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource DimForeground}" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="RenameFileOnClassifyCheck" Content="Rename files when classified" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Move and rename files to Branch/Section/DocType/ when document type is set or changed" 
                                       Foreground="{DynamicResource DimForeground}" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0" TextWrapping="Wrap"/>
                        </Grid>
                        <TextBlock Text="Archive" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource DimForeground}" Margin="0,16,0,12"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Retention period (years):" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="ArchiveRetentionYearsBox" Width="60" HorizontalAlignment="Left" Padding="6,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Default retention for archived documents (e.g. 7 for regulatory compliance)" 
                                       Foreground="{DynamicResource DimForeground}" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0" TextWrapping="Wrap"/>
                        </Grid>
                        <TextBlock Text="KPI Targets (Reports)" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource DimForeground}" Margin="0,16,0,12"/>
                        <TextBlock Text="KPI targets are used in Performance reports for variance analysis (target vs actual). Edit values and click Save to apply." 
                                   Foreground="{DynamicResource DimForeground}" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <DataGrid x:Name="KpiTargetsGrid" Margin="0,0,0,8" Height="180" AutoGenerateColumns="False"
                                  CanUserAddRows="True" CanUserDeleteRows="True"
                                  Background="{DynamicResource ContentBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource BorderBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="KPI" Binding="{Binding KpiName}" Width="120"/>
                                <DataGridTextColumn Header="Branch" Binding="{Binding Branch, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                                <DataGridTextColumn Header="Section" Binding="{Binding Section, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                                <DataGridTextColumn Header="Target" Binding="{Binding Target, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                                <DataGridTextColumn Header="Warning" Binding="{Binding Warning, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                                <DataGridTextColumn Header="Critical" Binding="{Binding Critical, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Text="Leave Branch/Section blank for bank-wide targets. Add rows for branch/section-specific targets (e.g. Main Branch, Clearing)." 
                                   Foreground="{DynamicResource DimForeground}" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="SaveKpiTargetsBtn" Content="Save KPI Targets" Padding="12,6" Margin="0,0,8,0" Click="SaveKpiTargets_Click"
                                    Background="#28A745" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            <Button x:Name="ResetKpiTargetsBtn" Content="Reset to Defaults" Padding="12,6" Margin="0,0,8,0" Click="ResetKpiTargets_Click"
                                    Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand"/>
                            <Button x:Name="AddKpiTargetBtn" Content="Add Target" Padding="12,6" Click="AddKpiTarget_Click"
                                    Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                        <TextBlock Text="Scheduled Reports" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource DimForeground}" Margin="0,16,0,12"/>
                        <TextBlock Text="When enabled and app is running, generates the selected report at the configured time. Requires app to be open." 
                                   Foreground="{DynamicResource DimForeground}" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <CheckBox x:Name="ScheduledReportsEnabledCheck" Content="Enable scheduled reports" Grid.Row="0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="Report:" VerticalAlignment="Center" Width="60"/>
                                <ComboBox x:Name="ScheduledReportTypeCombo" Width="160" Margin="4,0,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="Time:" VerticalAlignment="Center" Width="60"/>
                                <TextBox x:Name="ScheduledReportTimeBox" Width="60" Padding="6,4" Margin="4,0,0,0" ToolTip="HH:mm (e.g. 08:00)"/>
                            </StackPanel>
                            <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="Save to:" VerticalAlignment="Center" Width="60"/>
                                <TextBox x:Name="ScheduledReportOutputDirBox" Width="280" Padding="6,4" Margin="4,0,0,0" ToolTip="Folder path for scheduled reports (blank = temp)"/>
                            </StackPanel>
                            <StackPanel Grid.Row="4" Grid.Column="0" Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="Email to:" VerticalAlignment="Center" Width="60"/>
                                <TextBox x:Name="ScheduledReportEmailBox" Width="280" Padding="6,4" Margin="4,0,0,0" ToolTip="Comma-separated emails (blank = no email)"/>
                            </StackPanel>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="Optional. Recipients for scheduled report email. Requires SMTP settings below." 
                                       Foreground="{DynamicResource DimForeground}" FontSize="11" VerticalAlignment="Center" Margin="8,8,0,0" TextWrapping="Wrap"/>
                            <StackPanel Grid.Row="5" Grid.Column="0" Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="SMTP host:" VerticalAlignment="Center" Width="60"/>
                                <TextBox x:Name="SmtpHostBox" Width="180" Padding="6,4" Margin="4,0,0,0" ToolTip="e.g. smtp.gmail.com"/>
                            </StackPanel>
                            <StackPanel Grid.Row="6" Grid.Column="0" Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="SMTP port:" VerticalAlignment="Center" Width="60"/>
                                <TextBox x:Name="SmtpPortBox" Width="50" Padding="6,4" Margin="4,0,8,0" ToolTip="587 or 465"/>
                                <TextBlock Text="User:" VerticalAlignment="Center" Width="30" Margin="0,0,4,0"/>
                                <TextBox x:Name="SmtpUserBox" Width="100" Padding="6,4" Margin="0,0,8,0"/>
                                <TextBlock Text="Password:" VerticalAlignment="Center" Width="55" Margin="0,0,4,0"/>
                                <PasswordBox x:Name="SmtpPasswordBox" Width="100" Padding="6,4" ToolTip="SMTP password (stored in app settings)"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Webcam Document Scan" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource DimForeground}" Margin="0,16,0,12"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="270" MinWidth="270"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <CheckBox x:Name="EnableAutoCaptureCheck" Content="Default to Auto mode in webcam" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="When checked, Webcam opens with Auto selected (Manual and Auto are always selectable)" 
                                       Foreground="{DynamicResource DimForeground}" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0" TextWrapping="Wrap"/>
                            <CheckBox x:Name="ShowAutoCaptureTimerCheck" Grid.Row="1" Content="Show auto-capture cooldown timer in webcam status" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="When checked, Webcam shows countdown text (e.g. next capture in 7.9s) during cooldown." 
                                       Foreground="{DynamicResource DimForeground}" FontSize="11" VerticalAlignment="Center" Margin="8,8,0,0" TextWrapping="Wrap"/>
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="Auto-capture cooldown (seconds):" VerticalAlignment="Center" Width="190"/>
                                <TextBox x:Name="AutoCaptureCooldownSecondsBox" Width="60" MinWidth="56" Padding="6,4" Margin="4,0,0,0" ToolTip="Valid range: 1 to 30 seconds"/>
                            </StackPanel>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Delay before next auto-capture attempt. Use higher values to reduce accidental consecutive captures." 
                                       Foreground="{DynamicResource DimForeground}" FontSize="11" VerticalAlignment="Center" Margin="8,8,0,0" TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- OCR Tab (on-device text extraction) -->
            <TabItem x:Name="OcrTab" Header="OCR">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel Margin="8">
                        <TextBlock x:Name="OcrSectionIntroTitle" Text="OCR" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource DimForeground}" Margin="0,0,0,12"/>
                        <TextBlock x:Name="OcrSectionIntroBody" Text="On-device text extraction from scans and images using Tesseract and local tessdata files." 
                                   Foreground="{DynamicResource DimForeground}" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <CheckBox x:Name="OcrUseLayoutAssemblyCheck" Grid.Row="0" Content="Use layout-based line breaks" VerticalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock x:Name="OcrTesseractLayoutHint" Grid.Row="0" Grid.Column="1" Text="Recommended. Uncheck to use legacy flat text (rollback)." 
                                       Foreground="{DynamicResource DimForeground}" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,8" TextWrapping="Wrap"/>
                            <StackPanel x:Name="OcrTesseractPsmPanel" Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Page mode (PSM):" VerticalAlignment="Center" Width="110"/>
                                <ComboBox x:Name="OcrPsmCombo" Width="200" Margin="4,0,0,0"/>
                            </StackPanel>
                            <TextBlock x:Name="OcrTesseractPsmHint" Grid.Row="1" Grid.Column="1" Text="Tesseract segmentation (3 = automatic). Change if columns or sparse text OCR poorly." 
                                       Foreground="{DynamicResource DimForeground}" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,8" TextWrapping="Wrap"/>
                            <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Languages:" VerticalAlignment="Center" Width="110"/>
                                <ComboBox x:Name="OcrLanguageCombo" Width="200" Margin="4,0,0,0"/>
                            </StackPanel>
                            <TextBlock x:Name="OcrLanguageHint" Grid.Row="2" Grid.Column="1" Text="eng, ara, or both (eng+ara). Match installed .traineddata files." 
                                       Foreground="{DynamicResource DimForeground}" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,8" TextWrapping="Wrap"/>
                            <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="PDF render DPI:" VerticalAlignment="Center" Width="110"/>
                                <TextBox x:Name="OcrPdfDpiBox" Width="60" Padding="6,4" Margin="4,0,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="150–400. Higher can improve small text on scanned PDFs (slower, more memory)." 
                                       Foreground="{DynamicResource DimForeground}" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,8" TextWrapping="Wrap"/>
                            <StackPanel x:Name="OcrTesseractTessdataPanel" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Tessdata folder:" VerticalAlignment="Center" Width="110"/>
                                <TextBox x:Name="OcrTessdataPathBox" MinWidth="280" Padding="6,4" Margin="4,0,8,0" VerticalAlignment="Center"/>
                                <Button x:Name="OcrTessdataBrowseBtn" Content="Browse…" Padding="10,4" Click="OcrTessdataBrowse_Click"
                                        Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>
                            <TextBlock x:Name="OcrTesseractTessdataSubHint" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Text="Optional override. Leave blank to use application folder Tesseract/tessdata or legacy path." 
                                       Foreground="{DynamicResource DimForeground}" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <StackPanel x:Name="OcrTesseractDenoisePanel" Grid.Row="6" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Denoise (h):" VerticalAlignment="Center" Width="110"/>
                                <TextBox x:Name="OcrNlMeansHBox" Width="50" Padding="6,4" Margin="4,0,0,0" ToolTip="FastNlMeans 1–20"/>
                            </StackPanel>
                            <TextBlock x:Name="OcrTesseractDenoiseHint" Grid.Row="6" Grid.Column="1" Text="Preprocess denoise strength (default 3). Lower if thin strokes disappear." 
                                       Foreground="{DynamicResource DimForeground}" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,8" TextWrapping="Wrap"/>
                            <CheckBox x:Name="OcrEnableMultipassCheck" Grid.Row="7" Content="Enable multi-pass OCR" VerticalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock x:Name="OcrTesseractMultipassHint" Grid.Row="7" Grid.Column="1" Text="Runs multiple OCR passes with different preprocessing and segmentation, then merges best lines." 
                                       Foreground="{DynamicResource DimForeground}" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,8" TextWrapping="Wrap"/>
                            <StackPanel x:Name="OcrTesseractMergePanel" Grid.Row="8" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Merge strategy:" VerticalAlignment="Center" Width="110"/>
                                <ComboBox x:Name="OcrMergeModeCombo" Width="200" Margin="4,0,0,0"/>
                            </StackPanel>
                            <TextBlock x:Name="OcrTesseractMergeHint" Grid.Row="8" Grid.Column="1" Text="Accuracy favors cleaner lines; Balanced is faster and less aggressive." 
                                       Foreground="{DynamicResource DimForeground}" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,8" TextWrapping="Wrap"/>
                            <CheckBox x:Name="OcrOrganizeBilingualCheck" Grid.Row="9" Content="Organize OCR output into Arabic/English sections" VerticalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="9" Grid.Column="1" Text="Separates extracted lines into Arabic, English, and Mixed/Numbers blocks for easier review." 
                                       Foreground="{DynamicResource DimForeground}" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,8" TextWrapping="Wrap"/>
                            <StackPanel Grid.Row="10" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Structured confidence:" VerticalAlignment="Center" Width="110"/>
                                <TextBox x:Name="OcrStructuredMinConfidenceBox" Width="50" Padding="6,4" Margin="4,0,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Row="10" Grid.Column="1" Text="0–100 threshold for auto-filling account/ref/date/amount fields from OCR." 
                                       Foreground="{DynamicResource DimForeground}" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,8" TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Backup Settings Tab -->
            <TabItem x:Name="BackupTab" Header="Backup">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel Margin="8">
                        <TextBlock Text="Automatic Backup" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource DimForeground}" Margin="0,0,0,12"/>
                        <CheckBox x:Name="BackupEnabledCheck" Content="Enable automatic backups" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Backup interval (hours):" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="BackupIntervalBox" Width="80" HorizontalAlignment="Left" Padding="6,4"/>

                            <TextBlock Grid.Row="1" Text="Backups to retain:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="BackupRetentionBox" Width="80" HorizontalAlignment="Left" Padding="6,4" Margin="0,8,0,0"/>

                            <TextBlock Grid.Row="2" Text="Include document files:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <CheckBox Grid.Row="2" Grid.Column="1" x:Name="BackupIncludeDocsCheck" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        </Grid>

                        <Separator Margin="0,8,0,16"/>
                        <TextBlock Text="Manual Backup" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource DimForeground}" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BackupNowBtn" Content="Create Backup Now" Padding="12,6" Margin="0,0,8,0" Click="BackupNow_Click"
                                    Background="#0E639C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            <Button x:Name="RestoreBackupBtn" Content="Restore from Backup..." Padding="12,6" Click="RestoreBackup_Click"
                                    Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                        <TextBlock x:Name="LastBackupLabel" Text="Last backup: Never" Foreground="{DynamicResource DimForeground}" FontSize="11" Margin="0,12,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- System Info Tab -->
            <TabItem x:Name="SystemTab" Header="System">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel Margin="8">
                        <TextBlock Text="Application Information" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource DimForeground}" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Application version:" Foreground="{DynamicResource DimForeground}"/>
                            <TextBlock Grid.Column="1" x:Name="AppVersionLabel" Text="1.0.0" FontWeight="SemiBold"/>

                            <TextBlock Grid.Row="1" Text="Database version:" Foreground="{DynamicResource DimForeground}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DbVersionLabel" Text="-" Margin="0,4,0,0"/>

                            <TextBlock Grid.Row="2" Text="Database path:" Foreground="{DynamicResource DimForeground}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="DbPathLabel" Text="-" TextWrapping="Wrap" Margin="0,4,0,0"/>

                            <TextBlock Grid.Row="3" Text="Base directory:" Foreground="{DynamicResource DimForeground}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="BaseDirLabel" Text="-" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </Grid>

                        <TextBlock Text="Optional: Change Storage Paths" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource DimForeground}" Margin="0,16,0,8"/>
                        <TextBlock Text="You can optionally change where documents and the database are stored. Changes take effect after restarting the application."
                                   Foreground="{DynamicResource DimForeground}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Base directory:" Foreground="{DynamicResource DimForeground}" VerticalAlignment="Center"/>
                            <TextBox x:Name="BaseDirBox" Grid.Column="1" Margin="0,0,8,0" Padding="8,6" VerticalContentAlignment="Center"/>
                            <Button x:Name="BrowseBaseDirBtn" Grid.Column="2" Content="Browse..." Padding="12,6" Click="BrowseBaseDir_Click"
                                    Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand"/>
                            <TextBlock Grid.Row="1" Text="Database path:" Foreground="{DynamicResource DimForeground}" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox x:Name="DbPathBox" Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" Padding="8,6" VerticalContentAlignment="Center"/>
                            <Button x:Name="BrowseDbPathBtn" Grid.Row="1" Grid.Column="2" Content="Browse..." Padding="12,6" Margin="0,8,0,0" Click="BrowseDbPath_Click"
                                    Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand"/>
                        </Grid>

                        <Separator Margin="0,8,0,16"/>
                        <TextBlock Text="Database Statistics" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource DimForeground}" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Total documents:" Foreground="{DynamicResource DimForeground}"/>
                            <TextBlock Grid.Column="1" x:Name="TotalDocsLabel" Text="0"/>

                            <TextBlock Grid.Row="1" Text="Document types:" Foreground="{DynamicResource DimForeground}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DocTypesCountSystemLabel" Text="0" Margin="0,4,0,0"/>

                            <TextBlock Grid.Row="2" Text="Branches:" Foreground="{DynamicResource DimForeground}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="BranchesCountSystemLabel" Text="0" Margin="0,4,0,0"/>

                            <TextBlock Grid.Row="3" Text="Users:" Foreground="{DynamicResource DimForeground}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="UsersCountLabel" Text="0" Margin="0,4,0,0"/>

                            <TextBlock Grid.Row="4" Text="Database size:" Foreground="{DynamicResource DimForeground}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="DbSizeLabel" Text="0 KB" Margin="0,4,0,0"/>
                        </Grid>

                        <Button x:Name="RefreshSystemBtn" Content="Refresh Status" Padding="12,6" Margin="0,16,0,0" HorizontalAlignment="Left" Click="RefreshSystem_Click"
                                Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{DynamicResource ActivityBarBackground}" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusLabel" Text="Ready" Foreground="{DynamicResource DimForeground}" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="SaveBtn" Content="Save All Settings" Padding="16,8" Margin="0,0,8,0" Click="Save_Click"
                            Background="#0E639C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="CloseBtn" Content="Close" Padding="16,8" Click="Close_Click"
                            Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
