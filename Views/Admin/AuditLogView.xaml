<UserControl x:Class="WorkAudit.Views.Admin.AuditLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#F5F5F5" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Filters -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="From" Foreground="#333333" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <DatePicker x:Name="DateFrom" Width="120" Margin="0,0,16,0"/>
            <TextBlock Text="To" Foreground="#333333" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <DatePicker x:Name="DateTo" Width="120" Margin="0,0,16,0"/>
            <TextBlock Text="Category" Foreground="#333333" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <ComboBox x:Name="CategoryCombo" Width="120" Margin="0,0,16,0"/>
            <CheckBox x:Name="ArchiveRelatedOnlyCheck" Content="Archive-related only" Foreground="#333333" VerticalAlignment="Center" Margin="0,0,16,0"
                      ToolTip="Show only DocumentArchived, LegalHoldApplied, LegalHoldReleased, ArchiveExported, HashVerificationFailed"/>
            <Button Content="Refresh" Padding="12,6" Margin="0,0,8,0" Click="BtnRefresh_Click"/>
            <Button x:Name="ExportBtn" Content="Export for Regulators" Padding="12,6" Click="ExportBtn_Click"
                    ToolTip="Export audit log to CSV for compliance"/>
        </StackPanel>

        <!-- Log entries -->
        <DataGrid x:Name="LogGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                  Background="#FFFFFF" Foreground="#333333" RowBackground="#FFFFFF" AlternatingRowBackground="#F8F8F8"
                  BorderBrush="#E0E0E0" BorderThickness="1" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" CanUserAddRows="False" CanUserDeleteRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time" Binding="{Binding FormattedTimestamp}" Width="180"/>
                <DataGridTextColumn Header="User" Binding="{Binding Username}" Width="100"/>
                <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="120"/>
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="100"/>
                <DataGridTextColumn Header="Entity" Binding="{Binding EntityType}" Width="80"/>
                <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="StatusText" Grid.Row="2" Foreground="#555555" Margin="0,8,0,0" FontSize="12"/>
    </Grid>
</UserControl>
