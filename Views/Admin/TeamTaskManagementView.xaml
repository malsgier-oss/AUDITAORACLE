<UserControl x:Class="WorkAudit.Views.Admin.TeamTaskManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{DynamicResource PanelBackground}" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock x:Name="HeaderTitle" Text="Team task management" FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryForeground}"/>
            <TextBlock x:Name="HeaderSubtitle" Text="Assign recurring checklist tasks to users (daily, weekly, or monthly)."
                       FontSize="12" Foreground="{DynamicResource DimForeground}" Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="{DynamicResource ContentBackground}" Padding="12" Margin="0,0,0,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="FilterAssigneeLabel" Text="Assignee:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="AssigneeFilterCombo" Width="220" SelectionChanged="Filter_Changed"/>
                <Button x:Name="RefreshBtn" Content="Refresh" Padding="12,6" Margin="16,0,0,0" Click="RefreshBtn_Click"
                        Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource DimForeground}" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <DataGrid x:Name="TasksGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionChanged="TasksGrid_SelectionChanged"
                  Background="{DynamicResource ContentBackground}" RowBackground="{DynamicResource ContentBackground}"
                  AlternatingRowBackground="{DynamicResource AlternateRowBackground}"
                  Foreground="{DynamicResource DimForeground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                  GridLinesVisibility="Horizontal" HeadersVisibility="Column" CanUserAddRows="False" CanUserDeleteRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn x:Name="ColTitle" Header="Title" Binding="{Binding Title}" Width="*" MinWidth="160"/>
                <DataGridTextColumn x:Name="ColAssignee" Header="Assignee" Binding="{Binding AssigneeDisplay}" Width="140"/>
                <DataGridTextColumn x:Name="ColRecurrence" Header="Recurrence" Binding="{Binding RecurrenceDisplay}" Width="100"/>
                <DataGridTextColumn x:Name="ColStart" Header="Start" Binding="{Binding StartDate}" Width="100"/>
                <DataGridTextColumn x:Name="ColEnd" Header="End" Binding="{Binding EndDateDisplay}" Width="100"/>
                <DataGridTextColumn x:Name="ColActive" Header="Active" Binding="{Binding ActiveDisplay}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
            <Button x:Name="AddBtn" Content="Add" Padding="14,8" Margin="0,0,8,0" Click="AddBtn_Click"
                    Background="#0E639C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="EditBtn" Content="Edit" Padding="14,8" Margin="0,0,8,0" Click="EditBtn_Click" IsEnabled="False"
                    Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="DeleteBtn" Content="Delete" Padding="14,8" Margin="0,0,8,0" Click="DeleteBtn_Click" IsEnabled="False"
                    Background="#DC3545" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</UserControl>
