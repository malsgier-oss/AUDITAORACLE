<Window x:Class="WorkAudit.Views.Admin.AssignmentManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:WorkAudit.Views.Admin"
        Title="Assignment Management - AUDITA" Height="600" Width="1000" MinHeight="450" MinWidth="750"
        WindowStartupLocation="CenterOwner" WindowStyle="SingleBorderWindow"
        Background="{DynamicResource ContentBackground}">
    <TabControl>
        <TabItem Header="List">
            <views:AssignmentManagementView x:Name="ManagementContent"/>
        </TabItem>
        <TabItem Header="Calendar">
            <views:AssignmentCalendarView x:Name="CalendarContent"/>
        </TabItem>
        <TabItem Header="Analytics">
            <views:AssignmentAnalyticsView x:Name="AnalyticsContent"/>
        </TabItem>
    </TabControl>
</Window>
