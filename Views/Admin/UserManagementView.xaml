<UserControl x:Class="WorkAudit.Views.Admin.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#F5F5F5" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="BtnAdd" Content="Add User" Padding="12,6" Margin="0,0,8,0" Click="BtnAdd_Click"/>
            <Button x:Name="BtnEdit" Content="Edit" Padding="12,6" Margin="0,0,8,0" Click="BtnEdit_Click"/>
            <Button x:Name="BtnResetPassword" Content="Reset Password" Padding="12,6" Margin="0,0,8,0" Click="BtnResetPassword_Click"/>
            <Button x:Name="BtnEmergencyCodes" Content="Emergency codes…" Padding="12,6" Margin="0,0,8,0" Click="BtnEmergencyCodes_Click"/>
            <Button x:Name="BtnUnlock" Content="Unlock" Padding="12,6" Margin="0,0,8,0" Click="BtnUnlock_Click"/>
            <Button x:Name="BtnDelete" Content="Delete" Padding="12,6" Foreground="#F14C4C" Click="BtnDelete_Click"/>
            <Button x:Name="BtnRefresh" Content="Refresh" Padding="12,6" Margin="16,0,0,0" Click="BtnRefresh_Click"/>
        </StackPanel>

        <!-- User list (Active/Locked columns are editable; text columns are read-only) -->
        <DataGrid x:Name="UsersGrid" Grid.Row="1" AutoGenerateColumns="False"
                  SelectionMode="Single" SelectionChanged="UsersGrid_SelectionChanged"
                  CellEditEnding="UsersGrid_CellEditEnding"
                  Background="#FFFFFF" Foreground="#333333" RowBackground="#FFFFFF" AlternatingRowBackground="#F8F8F8"
                  BorderBrush="#E0E0E0" BorderThickness="1" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" CanUserAddRows="False" CanUserDeleteRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Header="Branch" Binding="{Binding Branch}" Width="140" IsReadOnly="True"/>
                <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180" IsReadOnly="True"/>
                <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                <DataGridCheckBoxColumn Header="Locked" Binding="{Binding IsLocked, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                <DataGridTextColumn Header="Failed Attempts" Binding="{Binding FailedLoginAttempts}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Last Login" Binding="{Binding LastLoginAt}" Width="140" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status -->
        <TextBlock x:Name="StatusText" Grid.Row="2" Foreground="#555555" Margin="0,8,0,0" FontSize="12"/>
    </Grid>
</UserControl>
