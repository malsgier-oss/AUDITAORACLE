<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- High Contrast Theme for WorkAudit -->
    <!-- Designed for Windows High Contrast Mode compliance -->
    
    <!-- Text Colors -->
    <SolidColorBrush x:Key="HighContrastTextBrush" Color="{DynamicResource {x:Static SystemColors.WindowTextColorKey}}" />
    <SolidColorBrush x:Key="HighContrastBackgroundBrush" Color="{DynamicResource {x:Static SystemColors.WindowColorKey}}" />
    <SolidColorBrush x:Key="HighContrastHighlightBrush" Color="{DynamicResource {x:Static SystemColors.HighlightColorKey}}" />
    <SolidColorBrush x:Key="HighContrastHighlightTextBrush" Color="{DynamicResource {x:Static SystemColors.HighlightTextColorKey}}" />
    
    <!-- Button Styles -->
    <Style x:Key="HighContrastButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource HighContrastTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource HighContrastBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource HighContrastTextBrush}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Bold" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource HighContrastHighlightBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource HighContrastHighlightTextBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource HighContrastHighlightBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource HighContrastHighlightTextBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.5" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- TextBox Styles -->
    <Style x:Key="HighContrastTextBoxStyle" TargetType="TextBox">
        <Setter Property="Foreground" Value="{DynamicResource HighContrastTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource HighContrastBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource HighContrastTextBrush}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="FontSize" Value="14" />
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource HighContrastHighlightBrush}" />
                <Setter Property="BorderThickness" Value="3" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ComboBox Styles -->
    <Style x:Key="HighContrastComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Foreground" Value="{DynamicResource HighContrastTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource HighContrastBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource HighContrastTextBrush}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <!-- DataGrid Styles -->
    <Style x:Key="HighContrastDataGridStyle" TargetType="DataGrid">
        <Setter Property="Foreground" Value="{DynamicResource HighContrastTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource HighContrastBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource HighContrastTextBrush}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="GridLinesVisibility" Value="All" />
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource HighContrastTextBrush}" />
        <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource HighContrastTextBrush}" />
        <Setter Property="RowBackground" Value="{DynamicResource HighContrastBackgroundBrush}" />
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource HighContrastBackgroundBrush}" />
    </Style>

    <!-- Label Styles -->
    <Style x:Key="HighContrastLabelStyle" TargetType="Label">
        <Setter Property="Foreground" Value="{DynamicResource HighContrastTextBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <!-- GroupBox Styles -->
    <Style x:Key="HighContrastGroupBoxStyle" TargetType="GroupBox">
        <Setter Property="Foreground" Value="{DynamicResource HighContrastTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource HighContrastTextBrush}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <!-- ListBox Styles -->
    <Style x:Key="HighContrastListBoxStyle" TargetType="ListBox">
        <Setter Property="Foreground" Value="{DynamicResource HighContrastTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource HighContrastBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource HighContrastTextBrush}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>

    <!-- Menu Styles -->
    <Style x:Key="HighContrastMenuStyle" TargetType="Menu">
        <Setter Property="Foreground" Value="{DynamicResource HighContrastTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource HighContrastBackgroundBrush}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <!-- TabControl Styles -->
    <Style x:Key="HighContrastTabControlStyle" TargetType="TabControl">
        <Setter Property="Foreground" Value="{DynamicResource HighContrastTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource HighContrastBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource HighContrastTextBrush}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>

    <!-- Window Styles -->
    <Style x:Key="HighContrastWindowStyle" TargetType="Window">
        <Setter Property="Foreground" Value="{DynamicResource HighContrastTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource HighContrastBackgroundBrush}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{DynamicResource {x:Static SystemColors.HighlightColorKey}}" />
    <SolidColorBrush x:Key="AccentSuccessBrush" Color="{DynamicResource {x:Static SystemColors.HighlightColorKey}}" />
    <SolidColorBrush x:Key="AccentDangerBrush" Color="{DynamicResource {x:Static SystemColors.HighlightColorKey}}" />
    <SolidColorBrush x:Key="AccentMutedBrush" Color="{DynamicResource {x:Static SystemColors.GrayTextColorKey}}" />

</ResourceDictionary>
