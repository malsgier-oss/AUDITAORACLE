<UserControl x:Class="WorkAudit.Controls.DocumentViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ContentBackground}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Zoom / Pan toolbar -->
        <Border Grid.Row="0" Background="{DynamicResource PanelBackground}" Padding="6,4" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="ZoomOutBtn" Content="−" ToolTip="Zoom out" Width="28" Height="24" Margin="0,0,2,0"
                        Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand" Click="ZoomOut_Click"/>
                <TextBlock x:Name="ZoomText" Text="100%" VerticalAlignment="Center" MinWidth="40" Margin="4,0"
                          Foreground="{DynamicResource DimForeground}" FontSize="12"/>
                <Button x:Name="ZoomInBtn" Content="+" ToolTip="Zoom in" Width="28" Height="24" Margin="2,0,8,0"
                        Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand" Click="ZoomIn_Click"/>
                <Button Content="◀" ToolTip="Pan left" Width="28" Height="24" Margin="0,0,2,0"
                        Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand" Click="PanLeft_Click"/>
                <Button Content="▶" ToolTip="Pan right" Width="28" Height="24" Margin="0,0,2,0"
                        Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand" Click="PanRight_Click"/>
                <Button Content="▲" ToolTip="Pan up" Width="28" Height="24" Margin="0,0,2,0"
                        Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand" Click="PanUp_Click"/>
                <Button Content="▼" ToolTip="Pan down" Width="28" Height="24" Margin="0,0,8,0"
                        Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand" Click="PanDown_Click"/>
                <Button x:Name="FitBtn" Content="Fit" ToolTip="Fit to view" Padding="8,4" Margin="0,0,2,0"
                        Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand" Click="Fit_Click"/>
                <Button x:Name="ActualSizeBtn" Content="100%" ToolTip="Actual size" Padding="8,4" Margin="0,0,8,0"
                        Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand" Click="ActualSize_Click"/>
                <Button x:Name="RotateBtn" Content="↻ 90°" ToolTip="Rotate 90°" Padding="8,4" Margin="0,0,8,0"
                        Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand" Click="Rotate_Click"/>
                <Rectangle x:Name="OcrToolbarSeparator" Width="1" Height="22" Margin="0,0,8,0"
                           Fill="{DynamicResource BorderBrush}" Visibility="Collapsed" VerticalAlignment="Center"/>
                <Button x:Name="OcrCopyTextBtn" Content="Copy text" Padding="10,4" Visibility="Collapsed"
                        ToolTip="Copy selected text (or all text in the focused block)"
                        Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand" Click="OcrCopyTextBtn_Click"/>
            </StackPanel>
        </Border>
        <ScrollViewer x:Name="Scroll" Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource ContentBackground}" CanContentScroll="True"
                      PreviewMouseWheel="Scroll_PreviewMouseWheel"
                      MouseLeftButtonDown="Scroll_MouseLeftButtonDown"
                      MouseLeftButtonUp="Scroll_MouseLeftButtonUp"
                      MouseMove="Scroll_MouseMove">
            <Border x:Name="ContentHost" Background="Transparent">
                <Border.LayoutTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="ScaleTransform" ScaleX="1" ScaleY="1"/>
                        <RotateTransform x:Name="RotateTransform" Angle="0"/>
                    </TransformGroup>
                </Border.LayoutTransform>
                <Grid x:Name="ImageMarkupGrid" HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Image x:Name="DocumentImage" Stretch="None" RenderOptions.BitmapScalingMode="HighQuality"
                           SizeChanged="DocumentImage_SizeChanged"/>
                    <Canvas x:Name="MarkupCanvas" Background="Transparent" IsHitTestVisible="False"
                            PreviewMouseLeftButtonDown="MarkupCanvas_PreviewMouseLeftButtonDown"
                            PreviewMouseMove="MarkupCanvas_PreviewMouseMove"
                            PreviewMouseLeftButtonUp="MarkupCanvas_PreviewMouseLeftButtonUp"/>
                    <Canvas x:Name="OcrOverlayCanvas" Panel.ZIndex="10" IsHitTestVisible="False" Visibility="Collapsed"/>
                </Grid>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
