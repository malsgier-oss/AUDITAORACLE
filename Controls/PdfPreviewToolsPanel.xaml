<UserControl x:Class="WorkAudit.Controls.PdfPreviewToolsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{DynamicResource PanelBackground}" Padding="6,4" Margin="0,0,0,4"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
        <StackPanel Orientation="Horizontal">
            <Button x:Name="PdfZoomOutBtn" Content="−" ToolTip="Zoom out" Width="28" Height="24" Margin="0,0,2,0"
                    Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand" Click="PdfZoomOut_Click"/>
            <TextBlock x:Name="PdfZoomLabel" Text="PDF" VerticalAlignment="Center" MinWidth="36" Margin="4,0"
                       Foreground="{DynamicResource DimForeground}" FontSize="11"/>
            <Button x:Name="PdfZoomInBtn" Content="+" ToolTip="Zoom in" Width="28" Height="24" Margin="2,0,8,0"
                    Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand" Click="PdfZoomIn_Click"/>
            <Button x:Name="PdfFitWidthBtn" Content="Fit width" ToolTip="Fit page width" Padding="8,4" Margin="0,0,8,0"
                    Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand" Click="PdfFitWidth_Click"/>
            <ToggleButton x:Name="PdfPanDragBtn" Content="Pan" IsChecked="True"
                          ToolTip="When on, drag on the page to move the view (when zoomed). Turn off to select text in the PDF."
                          Padding="8,4" Margin="0,0,8,0" Cursor="Hand"
                          Checked="PdfPanDrag_Checked" Unchecked="PdfPanDrag_Unchecked">
                <ToggleButton.Style>
                    <Style TargetType="ToggleButton">
                        <Setter Property="Background" Value="{DynamicResource ButtonSecondaryBackground}"/>
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ToggleButton.Style>
            </ToggleButton>
            <Button Content="◀" ToolTip="Pan left" Width="28" Height="24" Margin="0,0,2,0"
                    Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand" Click="PdfPanLeft_Click"/>
            <Button Content="▶" ToolTip="Pan right" Width="28" Height="24" Margin="0,0,2,0"
                    Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand" Click="PdfPanRight_Click"/>
            <Button Content="▲" ToolTip="Pan up" Width="28" Height="24" Margin="0,0,2,0"
                    Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand" Click="PdfPanUp_Click"/>
            <Button Content="▼" ToolTip="Pan down" Width="28" Height="24"
                    Background="{DynamicResource ButtonSecondaryBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0" Cursor="Hand" Click="PdfPanDown_Click"/>
        </StackPanel>
    </Border>
</UserControl>
